# Enforce LF line endings for all text files to prevent CRLF issues on Windows
* text=auto eol=lf

# Explicitly mark binary files
*.exe binary
*.o binary
*.a binary
*.wasm binary

# Shell scripts must be LF
*.sh text eol=lf

# Source files must be LF
*.zig text eol=lf
*.kl text eol=lf
*.expected text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
