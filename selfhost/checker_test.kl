// Isolate: returning types.get(i) from a function
import types.{KlarType, type_i32}

fn find_type(types: List#[KlarType], idx: i32) -> ?KlarType {
    return types.get(idx)
}

fn main() -> i32 {
    var types: List#[KlarType] = List.new#[KlarType]()
    types.push(type_i32())
    let r: ?KlarType = find_type(types, 0)
    match r {
        Some(_) => { println("OK: found") }
        None => { println("FAIL: not found"); return 1 }
    }
    return 0
}
