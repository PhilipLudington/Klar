// ─── 9.10.1 Helpers ──────────────────────────────────────────────────

fn add_generic_param(tc: TypeChecker, name: string) -> (TypeChecker, i32) {
    var c: TypeChecker = tc
    let idx: i32 = c.extra_generic_params.len()
    c.extra_generic_params.push(GenericParam {
        param_name: name,
        bound: no_type_expr(),
        span: s(),
    })
    return (c, idx)
}

fn add_call_expr_generic(tc: TypeChecker, callee: ExprId, args_start: i32, args_count: i32,
    ta_start: i32, ta_count: i32) -> (TypeChecker, ExprId) {
    var c: TypeChecker = tc
    let idx: i32 = c.exprs.len()
    c.exprs.push(Expr::Call(CallData {
        callee: callee,
        args_start: args_start,
        args_count: args_count,
        type_args_start: ta_start,
        type_args_count: ta_count,
        span: s(),
    }))
    return (c, ExprId { id: idx })
}

fn register_generic_fn(tc: TypeChecker, name: string, data: FunctionDeclData) -> TypeChecker {
    var c: TypeChecker = tc
    let idx: i32 = c.generic_fn_data.len()
    c.generic_fn_data.push(data)
    c.generic_fn_decls.insert(name, idx)
    return c
}

fn register_generic_struct(tc: TypeChecker, name: string, data: StructDeclData) -> TypeChecker {
    var c: TypeChecker = tc
    let idx: i32 = c.generic_struct_data.len()
    c.generic_struct_data.push(data)
    c.generic_struct_decls.insert(name, idx)
    return c
}

// ─── 9.10.1 Generic Monomorphization Tests ──────────────────────────

fn test_generic_fn_explicit() -> i32 {
    // fn identity#[T](x: T) -> T
    // identity#[i32](42) → i32
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // GenericParam "T"
    let gp_r: (TypeChecker, i32) = add_generic_param(tc, "T")
    tc = gp_r.0
    let gp_start: i32 = gp_r.1

    // Type expressions for param and return (both "T")
    let t_T1: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T1.0
    let t_T2: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T2.0

    // Param: x: T
    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "x", type_expr: t_T1.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    // Register generic function directly
    tc = register_generic_fn(tc, "identity", FunctionDeclData {
        fn_name: "identity",
        generics_start: gp_start, generics_count: 1,
        params_start: params_start, params_count: 1,
        return_type: t_T2.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    })

    // Build call: identity#[i32](42)
    let r_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "identity")
    tc = r_callee.0
    let r_arg: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_arg.0
    let args_start: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_arg.1)

    // Type arg: i32
    let ta_te: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = ta_te.0
    let ta_start: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(ta_te.1)

    let r_call: (TypeChecker, ExprId) = add_call_expr_generic(tc, r_callee.1, args_start, 1, ta_start, 1)
    tc = r_call.0

    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_type(re.1, type_i32(), "identity#[i32](42) → i32") { return 50 }
    if not expect_ok(tc, "generic fn explicit") { return 50 }

    return 0
}

fn test_generic_fn_inferred() -> i32 {
    // fn identity#[T](x: T) -> T
    // identity(42) infers T=i32 → returns i32
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let gp_r: (TypeChecker, i32) = add_generic_param(tc, "T")
    tc = gp_r.0
    let gp_start: i32 = gp_r.1

    let t_T1: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T1.0
    let t_T2: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T2.0

    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "x", type_expr: t_T1.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    tc = register_generic_fn(tc, "identity", FunctionDeclData {
        fn_name: "identity",
        generics_start: gp_start, generics_count: 1,
        params_start: params_start, params_count: 1,
        return_type: t_T2.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    })

    // Build call: identity(42) — no type args, inferred
    let r_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "identity")
    tc = r_callee.0
    let r_arg: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_arg.0
    let args_start: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_arg.1)

    let r_call: (TypeChecker, ExprId) = add_call_expr(tc, r_callee.1, args_start, 1)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_type(re.1, type_i32(), "identity(42) inferred → i32") { return 51 }
    if not expect_ok(tc, "generic fn inferred") { return 51 }

    return 0
}

fn test_generic_fn_cache() -> i32 {
    // Two calls with same type args should use cached monomorphization
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let gp_r: (TypeChecker, i32) = add_generic_param(tc, "T")
    tc = gp_r.0
    let gp_start: i32 = gp_r.1

    let t_T1: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T1.0
    let t_T2: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T2.0

    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "x", type_expr: t_T1.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    tc = register_generic_fn(tc, "identity", FunctionDeclData {
        fn_name: "identity",
        generics_start: gp_start, generics_count: 1,
        params_start: params_start, params_count: 1,
        return_type: t_T2.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    })

    // First call: identity(42)
    let r_c1: (TypeChecker, ExprId) = add_ident_expr(tc, "identity")
    tc = r_c1.0
    let r_a1: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_a1.0
    let as1: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_a1.1)
    let r_call1: (TypeChecker, ExprId) = add_call_expr(tc, r_c1.1, as1, 1)
    tc = r_call1.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_call1.1)
    tc = re1.0

    let fns_after_first: i32 = tc.mono_functions.len()

    // Second call: identity(99) — same type, should hit cache
    let r_c2: (TypeChecker, ExprId) = add_ident_expr(tc, "identity")
    tc = r_c2.0
    let r_a2: (TypeChecker, ExprId) = add_int_expr(tc, "99")
    tc = r_a2.0
    let as2: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_a2.1)
    let r_call2: (TypeChecker, ExprId) = add_call_expr(tc, r_c2.1, as2, 1)
    tc = r_call2.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_call2.1)
    tc = re2.0

    if not expect_type(re1.1, type_i32(), "first call → i32") { return 52 }
    if not expect_type(re2.1, type_i32(), "second call → i32 (cached)") { return 52 }
    // Cache size should not grow
    if tc.mono_functions.len() != fns_after_first {
        println("FAIL: test_generic_fn_cache — cache should not grow for same type args")
        return 52
    }
    if not expect_ok(tc, "generic fn cache") { return 52 }

    return 0
}

fn test_generic_fn_two_params() -> i32 {
    // fn first#[A, B](a: A, b: B) -> A
    // first#[i32, string](42, "hello") → i32
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let gp_a: (TypeChecker, i32) = add_generic_param(tc, "A")
    tc = gp_a.0
    let gp_start: i32 = gp_a.1
    let gp_b: (TypeChecker, i32) = add_generic_param(tc, "B")
    tc = gp_b.0

    let t_A1: (TypeChecker, TypeExprId) = add_type_named(tc, "A")
    tc = t_A1.0
    let t_B1: (TypeChecker, TypeExprId) = add_type_named(tc, "B")
    tc = t_B1.0
    let t_A2: (TypeChecker, TypeExprId) = add_type_named(tc, "A")
    tc = t_A2.0

    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "a", type_expr: t_A1.1, default_value: no_expr(), is_mut: false, span: s(),
    })
    tc.extra_params.push(FnParam {
        param_name: "b", type_expr: t_B1.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    tc = register_generic_fn(tc, "first", FunctionDeclData {
        fn_name: "first",
        generics_start: gp_start, generics_count: 2,
        params_start: params_start, params_count: 2,
        return_type: t_A2.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    })

    // Build call with explicit type args: first#[i32, string](42, "hello")
    let r_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "first")
    tc = r_callee.0
    let r_a1: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_a1.0
    let r_a2: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_a2.0
    let args_start: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_a1.1)
    tc.extra_expr_ids.push(r_a2.1)

    let ta_i32: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = ta_i32.0
    let ta_str: (TypeChecker, TypeExprId) = add_type_named(tc, "string")
    tc = ta_str.0
    let ta_start: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(ta_i32.1)
    tc.extra_type_expr_ids.push(ta_str.1)

    let r_call: (TypeChecker, ExprId) = add_call_expr_generic(tc, r_callee.1, args_start, 2, ta_start, 2)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_type(re.1, type_i32(), "first#[i32, string](42, \"hello\") → i32") { return 53 }
    if not expect_ok(tc, "generic fn two params") { return 53 }

    return 0
}

fn test_generic_fn_wrong_args() -> i32 {
    // fn identity#[T](x: T) -> T
    // identity(1, 2) → error (wrong arg count)
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let gp_r: (TypeChecker, i32) = add_generic_param(tc, "T")
    tc = gp_r.0
    let gp_start: i32 = gp_r.1

    let t_T1: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T1.0
    let t_T2: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T2.0

    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "x", type_expr: t_T1.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    tc = register_generic_fn(tc, "identity", FunctionDeclData {
        fn_name: "identity",
        generics_start: gp_start, generics_count: 1,
        params_start: params_start, params_count: 1,
        return_type: t_T2.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    })

    // Call with wrong arg count: identity(1, 2)
    let r_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "identity")
    tc = r_callee.0
    let r_a1: (TypeChecker, ExprId) = add_int_expr(tc, "1")
    tc = r_a1.0
    let r_a2: (TypeChecker, ExprId) = add_int_expr(tc, "2")
    tc = r_a2.0
    let args_start: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_a1.1)
    tc.extra_expr_ids.push(r_a2.1)

    let r_call: (TypeChecker, ExprId) = add_call_expr(tc, r_callee.1, args_start, 2)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_errors(tc, 1, "identity(1, 2) → wrong arg count error") { return 54 }

    return 0
}

fn test_generic_struct_instantiation() -> i32 {
    // struct Pair#[A, B] { first: A, second: B }
    // Pair#[i32, string] → StructType
    var tc: TypeChecker = TypeChecker.new()

    let gp_a: (TypeChecker, i32) = add_generic_param(tc, "A")
    tc = gp_a.0
    let gp_start: i32 = gp_a.1
    let gp_b: (TypeChecker, i32) = add_generic_param(tc, "B")
    tc = gp_b.0

    let t_A: (TypeChecker, TypeExprId) = add_type_named(tc, "A")
    tc = t_A.0
    let t_B: (TypeChecker, TypeExprId) = add_type_named(tc, "B")
    tc = t_B.0

    let fields_start: i32 = tc.extra_struct_fields.len()
    tc.extra_struct_fields.push(StructField { field_name: "first", type_expr: t_A.1, span: s() })
    tc.extra_struct_fields.push(StructField { field_name: "second", type_expr: t_B.1, span: s() })

    tc = register_generic_struct(tc, "Pair", StructDeclData {
        struct_name: "Pair",
        generics_start: gp_start, generics_count: 2,
        fields_start: fields_start, fields_count: 2,
        is_pub: true, is_extern: false, is_packed: false,
        span: s(),
    })

    // Build type expr: Pair#[i32, string]
    let t_base: (TypeChecker, TypeExprId) = add_type_named(tc, "Pair")
    tc = t_base.0
    let t_i32: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32.0
    let t_str: (TypeChecker, TypeExprId) = add_type_named(tc, "string")
    tc = t_str.0

    let te_args_start: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(t_i32.1)
    tc.extra_type_expr_ids.push(t_str.1)

    let r_ga: (TypeChecker, TypeExprId) = add_type_generic_apply(tc, t_base.1, te_args_start, 2)
    tc = r_ga.0

    let res: (TypeChecker, KlarType) = resolve_type_expr(tc, r_ga.1)
    tc = res.0
    if not expect_kind(res.1, "StructType", "Pair#[i32, string] → StructType") { return 55 }
    if not expect_ok(tc, "generic struct instantiation") { return 55 }

    return 0
}

fn test_generic_struct_field_access() -> i32 {
    // struct Pair#[A, B] { first: A, second: B }
    // p: Pair#[i32, string]; p.first → i32, p.second → string
    var tc: TypeChecker = TypeChecker.new()

    let gp_a: (TypeChecker, i32) = add_generic_param(tc, "A")
    tc = gp_a.0
    let gp_start: i32 = gp_a.1
    let gp_b: (TypeChecker, i32) = add_generic_param(tc, "B")
    tc = gp_b.0

    let t_A: (TypeChecker, TypeExprId) = add_type_named(tc, "A")
    tc = t_A.0
    let t_B: (TypeChecker, TypeExprId) = add_type_named(tc, "B")
    tc = t_B.0

    let fields_start: i32 = tc.extra_struct_fields.len()
    tc.extra_struct_fields.push(StructField { field_name: "first", type_expr: t_A.1, span: s() })
    tc.extra_struct_fields.push(StructField { field_name: "second", type_expr: t_B.1, span: s() })

    tc = register_generic_struct(tc, "Pair", StructDeclData {
        struct_name: "Pair",
        generics_start: gp_start, generics_count: 2,
        fields_start: fields_start, fields_count: 2,
        is_pub: true, is_extern: false, is_packed: false,
        span: s(),
    })

    // Resolve Pair#[i32, string]
    let t_base: (TypeChecker, TypeExprId) = add_type_named(tc, "Pair")
    tc = t_base.0
    let t_i32: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32.0
    let t_str: (TypeChecker, TypeExprId) = add_type_named(tc, "string")
    tc = t_str.0

    let te_args_start: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(t_i32.1)
    tc.extra_type_expr_ids.push(t_str.1)

    let r_ga: (TypeChecker, TypeExprId) = add_type_generic_apply(tc, t_base.1, te_args_start, 2)
    tc = r_ga.0

    let res: (TypeChecker, KlarType) = resolve_type_expr(tc, r_ga.1)
    tc = res.0
    let pair_type: KlarType = res.1

    // Define variable p of this type
    tc.push_scope()
    tc.define("p", SymbolInfo {
        sym_name: "p", sym_type: pair_type, mutable: false, kind: SymbolKind::Variable,
    })

    // p.first → i32
    let r_p1: (TypeChecker, ExprId) = add_ident_expr(tc, "p")
    tc = r_p1.0
    let r_first: (TypeChecker, ExprId) = add_field_expr(tc, r_p1.1, "first")
    tc = r_first.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_first.1)
    tc = re1.0
    if not expect_type(re1.1, type_i32(), "Pair.first → i32") { return 56 }

    // p.second → string
    let r_p2: (TypeChecker, ExprId) = add_ident_expr(tc, "p")
    tc = r_p2.0
    let r_second: (TypeChecker, ExprId) = add_field_expr(tc, r_p2.1, "second")
    tc = r_second.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_second.1)
    tc = re2.0
    if not expect_type(re2.1, type_string(), "Pair.second → string") { return 56 }

    if not expect_ok(tc, "generic struct field access") { return 56 }

    return 0
}

fn test_generic_struct_cache() -> i32 {
    // Same type args should reuse cached struct
    var tc: TypeChecker = TypeChecker.new()

    let gp_a: (TypeChecker, i32) = add_generic_param(tc, "A")
    tc = gp_a.0
    let gp_start: i32 = gp_a.1
    let gp_b: (TypeChecker, i32) = add_generic_param(tc, "B")
    tc = gp_b.0

    let t_A: (TypeChecker, TypeExprId) = add_type_named(tc, "A")
    tc = t_A.0
    let t_B: (TypeChecker, TypeExprId) = add_type_named(tc, "B")
    tc = t_B.0

    let fields_start: i32 = tc.extra_struct_fields.len()
    tc.extra_struct_fields.push(StructField { field_name: "first", type_expr: t_A.1, span: s() })
    tc.extra_struct_fields.push(StructField { field_name: "second", type_expr: t_B.1, span: s() })

    tc = register_generic_struct(tc, "Pair", StructDeclData {
        struct_name: "Pair",
        generics_start: gp_start, generics_count: 2,
        fields_start: fields_start, fields_count: 2,
        is_pub: true, is_extern: false, is_packed: false,
        span: s(),
    })

    // First resolution: Pair#[i32, string]
    let t_base1: (TypeChecker, TypeExprId) = add_type_named(tc, "Pair")
    tc = t_base1.0
    let t_i32_1: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_1.0
    let t_str_1: (TypeChecker, TypeExprId) = add_type_named(tc, "string")
    tc = t_str_1.0
    let te_as1: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(t_i32_1.1)
    tc.extra_type_expr_ids.push(t_str_1.1)
    let r_ga1: (TypeChecker, TypeExprId) = add_type_generic_apply(tc, t_base1.1, te_as1, 2)
    tc = r_ga1.0
    let res1: (TypeChecker, KlarType) = resolve_type_expr(tc, r_ga1.1)
    tc = res1.0

    let structs_after_first: i32 = tc.mono_structs.len()

    // Second resolution: Pair#[i32, string] (same args)
    let t_base2: (TypeChecker, TypeExprId) = add_type_named(tc, "Pair")
    tc = t_base2.0
    let t_i32_2: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_2.0
    let t_str_2: (TypeChecker, TypeExprId) = add_type_named(tc, "string")
    tc = t_str_2.0
    let te_as2: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(t_i32_2.1)
    tc.extra_type_expr_ids.push(t_str_2.1)
    let r_ga2: (TypeChecker, TypeExprId) = add_type_generic_apply(tc, t_base2.1, te_as2, 2)
    tc = r_ga2.0
    let res2: (TypeChecker, KlarType) = resolve_type_expr(tc, r_ga2.1)
    tc = res2.0

    // Both should be StructType
    if not expect_kind(res1.1, "StructType", "first Pair#[i32, string]") { return 57 }
    if not expect_kind(res2.1, "StructType", "second Pair#[i32, string]") { return 57 }

    // Cache should not grow
    if tc.mono_structs.len() != structs_after_first {
        println("FAIL: test_generic_struct_cache — cache should not grow for same type args")
        return 57
    }

    // Both should have same payload (same struct index)
    if res1.1.payload != res2.1.payload {
        println("FAIL: test_generic_struct_cache — cached struct should have same payload")
        return 57
    }

    if not expect_ok(tc, "generic struct cache") { return 57 }
    return 0
}

fn test_postfix_try_error_on_non_optional() -> i32 {
    var tc: TypeChecker = TypeChecker.new()
    tc.push_scope()

    // x: i32, x? → error
    tc.define("x", SymbolInfo {
        sym_name: "x", sym_type: type_i32(), mutable: false, kind: SymbolKind::Variable,
    })
    let r_x: (TypeChecker, ExprId) = add_ident_expr(tc, "x")
    tc = r_x.0
    let r_try: (TypeChecker, ExprId) = add_postfix_expr(tc, PostfixOp::Try, r_x.1)
    tc = r_try.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_try.1)
    tc = re.0
    if not expect_errors(tc, 1, "postfix ? on i32 → error") { return 40 }

    return 0
}

fn test_generic_fn_explicit_wrong_arg_type() -> i32 {
    // fn identity#[T](x: T) -> T
    // identity#[i32]("hello") → error (expected i32, got string)
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let gp_r: (TypeChecker, i32) = add_generic_param(tc, "T")
    tc = gp_r.0
    let gp_start: i32 = gp_r.1

    let t_T1: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T1.0
    let t_T2: (TypeChecker, TypeExprId) = add_type_named(tc, "T")
    tc = t_T2.0

    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "x", type_expr: t_T1.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    tc = register_generic_fn(tc, "identity", FunctionDeclData {
        fn_name: "identity",
        generics_start: gp_start, generics_count: 1,
        params_start: params_start, params_count: 1,
        return_type: t_T2.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    })

    // Build call: identity#[i32]("hello") — type arg says i32, but arg is string
    let r_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "identity")
    tc = r_callee.0
    let r_arg: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_arg.0
    let args_start: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_arg.1)

    let ta_te: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = ta_te.0
    let ta_start: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(ta_te.1)

    let r_call: (TypeChecker, ExprId) = add_call_expr_generic(tc, r_callee.1, args_start, 1, ta_start, 1)
    tc = r_call.0

    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_errors(tc, 1, "identity#[i32](\"hello\") → type mismatch error") { return 58 }

    return 0
}

fn test_interpolated_string_checks_parts() -> i32 {
    // "hello {undefined_var}" → should catch undefined variable in interpolation part
    var tc: TypeChecker = TypeChecker.new()

    // Build parts: string literal "hello ", then identifier "undefined_var"
    let r_s: (TypeChecker, ExprId) = add_str_expr(tc, "hello ")
    tc = r_s.0
    let r_bad: (TypeChecker, ExprId) = add_ident_expr(tc, "undefined_var")
    tc = r_bad.0

    let parts_start: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_s.1)
    tc.extra_expr_ids.push(r_bad.1)

    let interp_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::InterpolatedString(InterpolatedStringData {
        parts_start: parts_start, parts_count: 2, span: s(),
    }))
    let interp_eid: ExprId = ExprId { id: interp_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, interp_eid)
    tc = re.0
    if not expect_errors(tc, 1, "interpolated string with undefined var → error") { return 59 }
    if not expect_type(re.1, type_string(), "interpolated string → string") { return 59 }

    return 0
}

// ─── 9.10.2 Trait Resolution Tests ───────────────────────────────────

fn test_trait_definition() -> i32 {
    // Register a user-defined trait via the decl pipeline
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Build trait: trait Summable { fn sum(self) -> i32 }
    // Method decl
    let t_ret: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_ret.0
    let self_te: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = self_te.0

    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "self", type_expr: self_te.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    let method_decl_idx: i32 = tc.decls.len()
    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "sum",
        generics_start: 0, generics_count: 0,
        params_start: params_start, params_count: 1,
        return_type: t_ret.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    // TraitDecl
    let trait_decl_idx: i32 = tc.decls.len()
    tc.decls.push(Decl::TraitDecl(TraitDeclData {
        trait_name: "Summable",
        generics_start: 0, generics_count: 0,
        parents_start: 0, parents_count: 0,
        methods_start: method_decl_idx, methods_count: 1,
        assoc_types_start: 0, assoc_types_count: 0,
        is_pub: false, span: s(),
    }))

    tc = register_declarations(tc, trait_decl_idx, 1)
    if not expect_ok(tc, "register trait Summable") { return 60 }

    // Verify trait is in trait_types
    if not tc.trait_types.contains_key("Summable") {
        println("FAIL: test_trait_definition — Summable not in trait_types")
        return 60
    }
    let opt: ?KlarType = tc.trait_types.get("Summable")
    match opt {
        Some(t) => {
            if not expect_kind(t, "TraitType", "Summable is TraitType") { return 60 }
        }
        None => {
            println("FAIL: test_trait_definition — Summable get returned None")
            return 60
        }
    }

    return 0
}

fn test_trait_impl_registers_methods() -> i32 {
    // struct Foo { val: i32 }
    // trait Summable { fn sum(self) -> i32 }
    // impl Foo: Summable { fn sum(self) -> i32 { return self.val } }
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Struct Foo
    let t_i32_1: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_1.0
    let fields_start: i32 = tc.extra_struct_fields.len()
    tc.extra_struct_fields.push(StructField { field_name: "val", type_expr: t_i32_1.1, span: s() })

    let decl_start: i32 = tc.decls.len()
    tc.decls.push(Decl::StructDecl(StructDeclData {
        struct_name: "Foo",
        generics_start: 0, generics_count: 0,
        fields_start: fields_start, fields_count: 1,
        is_pub: true, is_extern: false, is_packed: false,
        span: s(),
    }))

    // Trait Summable: fn sum(self) -> i32
    let t_sum_ret: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_sum_ret.0
    let self_te: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = self_te.0
    let tp_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "self", type_expr: self_te.1, default_value: no_expr(), is_mut: false, span: s(),
    })
    let method_decl_idx: i32 = tc.decls.len()
    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "sum",
        generics_start: 0, generics_count: 0,
        params_start: tp_start, params_count: 1,
        return_type: t_sum_ret.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))
    tc.decls.push(Decl::TraitDecl(TraitDeclData {
        trait_name: "Summable",
        generics_start: 0, generics_count: 0,
        parents_start: 0, parents_count: 0,
        methods_start: method_decl_idx, methods_count: 1,
        assoc_types_start: 0, assoc_types_count: 0,
        is_pub: false, span: s(),
    }))

    // Impl Foo: Summable { fn sum(self) -> i32 { return self.val } }
    let impl_ret: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = impl_ret.0
    let self_te2: (TypeChecker, TypeExprId) = add_type_named(tc, "Foo")
    tc = self_te2.0
    let imp_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "self", type_expr: self_te2.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    // Body: return self.val
    let r_self: (TypeChecker, ExprId) = add_ident_expr(tc, "self")
    tc = r_self.0
    let r_val: (TypeChecker, ExprId) = add_field_expr(tc, r_self.1, "val")
    tc = r_val.0
    let r_ret: (TypeChecker, StmtId) = add_return_stmt(tc, r_val.1)
    tc = r_ret.0
    let body_start: i32 = tc.extra_stmt_ids.len()
    tc.extra_stmt_ids.push(r_ret.1)

    let impl_method_idx: i32 = tc.decls.len()
    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "sum",
        generics_start: 0, generics_count: 0,
        params_start: imp_start, params_count: 1,
        return_type: impl_ret.1,
        body_start: body_start, body_count: 1,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    tc.decls.push(Decl::ImplDecl(ImplDeclData {
        target_type: "Foo",
        impl_trait: "Summable",
        generics_start: 0, generics_count: 0,
        methods_start: impl_method_idx, methods_count: 1,
        assoc_types_start: 0, assoc_types_count: 0,
        span: s(),
    }))

    // Run full pipeline
    let decl_count: i32 = tc.decls.len() - decl_start
    tc = check_module(tc, decl_start, decl_count)
    if not expect_ok(tc, "impl Foo: Summable") { return 61 }

    // Verify method is registered
    if not tc.methods.contains_key("Foo.sum") {
        println("FAIL: test_trait_impl_registers_methods — Foo.sum not in methods")
        return 61
    }

    return 0
}

fn test_trait_impl_records_key() -> i32 {
    // Verify that impl Foo: Summable creates "Foo:Summable" in trait_impl_keys
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Must have the trait and struct registered
    let t1: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t1.0
    let fs: i32 = tc.extra_struct_fields.len()
    tc.extra_struct_fields.push(StructField { field_name: "x", type_expr: t1.1, span: s() })

    let ds: i32 = tc.decls.len()
    tc.decls.push(Decl::StructDecl(StructDeclData {
        struct_name: "Bar",
        generics_start: 0, generics_count: 0,
        fields_start: fs, fields_count: 1,
        is_pub: true, is_extern: false, is_packed: false,
        span: s(),
    }))

    // Trait Marker (no methods)
    tc.decls.push(Decl::TraitDecl(TraitDeclData {
        trait_name: "Marker",
        generics_start: 0, generics_count: 0,
        parents_start: 0, parents_count: 0,
        methods_start: 0, methods_count: 0,
        assoc_types_start: 0, assoc_types_count: 0,
        is_pub: false, span: s(),
    }))

    // impl Bar: Marker {}
    tc.decls.push(Decl::ImplDecl(ImplDeclData {
        target_type: "Bar",
        impl_trait: "Marker",
        generics_start: 0, generics_count: 0,
        methods_start: 0, methods_count: 0,
        assoc_types_start: 0, assoc_types_count: 0,
        span: s(),
    }))

    let dc: i32 = tc.decls.len() - ds
    tc = check_module(tc, ds, dc)
    if not expect_ok(tc, "impl Bar: Marker") { return 62 }

    if not has_trait_impl(tc, "Bar", "Marker") {
        println("FAIL: test_trait_impl_records_key — Bar:Marker not recorded")
        return 62
    }

    return 0
}

fn test_trait_method_through_bounds() -> i32 {
    // Test: generic fn with T: Summable bound, call item.sum()
    // trait Summable { fn sum(self) -> i32 }
    // fn total#[T: Summable](item: T) -> i32 { return item.sum() }
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Register trait Summable with method sum -> i32
    let t_ret: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_ret.0
    let self_te: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = self_te.0
    let tp_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "self", type_expr: self_te.1, default_value: no_expr(), is_mut: false, span: s(),
    })
    let method_di: i32 = tc.decls.len()
    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "sum",
        generics_start: 0, generics_count: 0,
        params_start: tp_start, params_count: 1,
        return_type: t_ret.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    let ds: i32 = tc.decls.len()
    tc.decls.push(Decl::TraitDecl(TraitDeclData {
        trait_name: "Summable",
        generics_start: 0, generics_count: 0,
        parents_start: 0, parents_count: 0,
        methods_start: method_di, methods_count: 1,
        assoc_types_start: 0, assoc_types_count: 0,
        is_pub: false, span: s(),
    }))

    // Register declarations first (so trait is available)
    let dc: i32 = tc.decls.len() - ds
    tc = register_declarations(tc, ds, dc)
    if not expect_ok(tc, "register trait Summable for bounds test") { return 63 }

    // Now manually create a TypeVar with Summable bound
    // Get the trait index
    let summable_opt: ?KlarType = tc.trait_types.get("Summable")
    var summable_trait_idx: i32 = 0
    match summable_opt {
        Some(t) => { summable_trait_idx = t.payload }
        None => {
            println("FAIL: test_trait_method_through_bounds — Summable not found")
            return 63
        }
    }

    // Create TypeVar T with bounds [Summable]
    let tvr: (TypeChecker, KlarType) = make_type_var_with_bounds(tc, 0, "T", summable_trait_idx, 1)
    tc = tvr.0
    let tv_type: KlarType = tvr.1

    // Define 'item' as type T in scope
    tc.push_scope()
    tc.define("item", SymbolInfo {
        sym_name: "item", sym_type: tv_type, mutable: false, kind: SymbolKind::Variable,
    })

    // Build: item.sum()
    let r_item: (TypeChecker, ExprId) = add_ident_expr(tc, "item")
    tc = r_item.0
    let r_call: (TypeChecker, ExprId) = add_method_call_expr(tc, r_item.1, "sum", 0, 0)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0

    if not expect_ok(tc, "item.sum() through Summable bound") { return 63 }
    if not expect_type(re.1, type_i32(), "item.sum() returns i32") { return 63 }

    tc.pop_scope()
    return 0
}

fn test_trait_unknown_method_error() -> i32 {
    // TypeVar T with Summable bound, call item.nonexistent() → error
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Register trait Summable
    let t_ret: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_ret.0
    let self_te: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = self_te.0
    let tp_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "self", type_expr: self_te.1, default_value: no_expr(), is_mut: false, span: s(),
    })
    let method_di: i32 = tc.decls.len()
    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "sum",
        generics_start: 0, generics_count: 0,
        params_start: tp_start, params_count: 1,
        return_type: t_ret.1,
        body_start: 0, body_count: 0,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))
    let ds: i32 = tc.decls.len()
    tc.decls.push(Decl::TraitDecl(TraitDeclData {
        trait_name: "Summable",
        generics_start: 0, generics_count: 0,
        parents_start: 0, parents_count: 0,
        methods_start: method_di, methods_count: 1,
        assoc_types_start: 0, assoc_types_count: 0,
        is_pub: false, span: s(),
    }))
    tc = register_declarations(tc, ds, tc.decls.len() - ds)

    // TypeVar with Summable bound
    let summable_opt: ?KlarType = tc.trait_types.get("Summable")
    var idx: i32 = 0
    match summable_opt {
        Some(t) => { idx = t.payload }
        None => { return 64 }
    }
    let tvr: (TypeChecker, KlarType) = make_type_var_with_bounds(tc, 0, "T", idx, 1)
    tc = tvr.0

    tc.push_scope()
    tc.define("item", SymbolInfo {
        sym_name: "item", sym_type: tvr.1, mutable: false, kind: SymbolKind::Variable,
    })

    // item.nonexistent() → error
    let r_item: (TypeChecker, ExprId) = add_ident_expr(tc, "item")
    tc = r_item.0
    let r_call: (TypeChecker, ExprId) = add_method_call_expr(tc, r_item.1, "nonexistent", 0, 0)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0

    if not expect_errors(tc, 1, "item.nonexistent() on bounded TypeVar → error") { return 64 }

    tc.pop_scope()
    return 0
}

fn test_builtin_eq_trait() -> i32 {
    // Verify builtin Eq trait is registered
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    if not tc.trait_types.contains_key("Eq") {
        println("FAIL: test_builtin_eq_trait — Eq not in trait_types")
        return 65
    }

    // Verify i32 implements Eq
    if not has_trait_impl(tc, "i32", "Eq") {
        println("FAIL: test_builtin_eq_trait — i32:Eq not recorded")
        return 65
    }
    // Verify string implements Eq
    if not has_trait_impl(tc, "string", "Eq") {
        println("FAIL: test_builtin_eq_trait — string:Eq not recorded")
        return 65
    }
    // Verify f64 implements Eq
    if not has_trait_impl(tc, "f64", "Eq") {
        println("FAIL: test_builtin_eq_trait — f64:Eq not recorded")
        return 65
    }

    // Verify Eq has method "eq"
    let eq_opt: ?KlarType = tc.trait_types.get("Eq")
    match eq_opt {
        Some(t) => {
            let td: TraitData = tc.type_traits[t.payload]
            let found: ?TraitMethodData = find_trait_method(tc, td, "eq")
            match found {
                Some(_) => {}
                None => {
                    println("FAIL: test_builtin_eq_trait — Eq has no 'eq' method")
                    return 65
                }
            }
        }
        None => {
            println("FAIL: test_builtin_eq_trait — Eq get returned None")
            return 65
        }
    }

    return 0
}

