fn test_generic_apply_list() -> i32 {
    // Build TypeExpr for List#[i32] and resolve it
    var tc: TypeChecker = TypeChecker.new()

    // TypeExpr::Named("List") for the base
    let r_base: (TypeChecker, TypeExprId) = add_type_named(tc, "List")
    tc = r_base.0

    // TypeExpr::Named("i32") for the type arg
    let r_arg: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = r_arg.0

    // Store type arg in extra_type_expr_ids
    let te_args_start: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(r_arg.1)

    // GenericApply: List#[i32]
    let r_ga: (TypeChecker, TypeExprId) = add_type_generic_apply(tc, r_base.1, te_args_start, 1)
    tc = r_ga.0

    let res: (TypeChecker, KlarType) = resolve_type_expr(tc, r_ga.1)
    tc = res.0
    if not expect_kind(res.1, "ListType", "List#[i32] resolves to ListType") { return 26 }
    if not expect_ok(tc, "GenericApply List#[i32]") { return 26 }

    return 0
}

