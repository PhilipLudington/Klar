    let rr: (TypeChecker, KlarType) = make_result_type(tc, type_i32(), type_string())
    tc = rr.0
    tc.define("res", SymbolInfo {
        sym_name: "res", sym_type: rr.1, mutable: false, kind: SymbolKind::Variable,
    })

    // res.is_ok() → bool
    let r_r: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_r.0
    let r_iok: (TypeChecker, ExprId) = add_method_call_expr(tc, r_r.1, "is_ok", 0, 0)
    tc = r_iok.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_iok.1)
    tc = re1.0
    if not expect_type(re1.1, type_bool(), "Result.is_ok() → bool") { return 36 }

    // res.unwrap() → i32
    let r_r2: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_r2.0
    let r_uw: (TypeChecker, ExprId) = add_method_call_expr(tc, r_r2.1, "unwrap", 0, 0)
    tc = r_uw.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_uw.1)
    tc = re2.0
    if not expect_type(re2.1, type_i32(), "Result.unwrap() → i32") { return 36 }

    // res.unwrap_err() → string
    let r_r3: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_r3.0
    let r_ue: (TypeChecker, ExprId) = add_method_call_expr(tc, r_r3.1, "unwrap_err", 0, 0)
    tc = r_ue.0
    let re3: (TypeChecker, KlarType) = check_expr(tc, r_ue.1)
    tc = re3.0
    if not expect_type(re3.1, type_string(), "Result.unwrap_err() → string") { return 36 }

    // res.ok() → ?i32
    let r_r4: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_r4.0
    let r_ok: (TypeChecker, ExprId) = add_method_call_expr(tc, r_r4.1, "ok", 0, 0)
    tc = r_ok.0
    let re4: (TypeChecker, KlarType) = check_expr(tc, r_ok.1)
    tc = re4.0
    if not expect_kind(re4.1, "Optional", "Result.ok() → Optional") { return 36 }

    if not expect_ok(tc, "result methods") { return 36 }
    return 0
}

fn test_parse_int_builtin() -> i32 {
