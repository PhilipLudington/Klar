fn main() -> i32 {
    println("=== Self-hosted Type Checker Tests ===")
    var rc: i32 = 0

    rc = test_literal_types()
    if rc != 0 { return rc }

    rc = test_identifier_lookup()
    if rc != 0 { return rc }

    rc = test_binary_ops()
    if rc != 0 { return rc }

    rc = test_binary_type_errors()
    if rc != 0 { return rc }

    rc = test_unary_ops()
    if rc != 0 { return rc }

    rc = test_let_decl()
    if rc != 0 { return rc }

    rc = test_let_type_mismatch()
    if rc != 0 { return rc }

    rc = test_var_and_assignment()
    if rc != 0 { return rc }

    rc = test_assign_to_immutable()
    if rc != 0 { return rc }

    rc = test_return_type_check()
    if rc != 0 { return rc }

    rc = test_if_condition_type()
    if rc != 0 { return rc }

    rc = test_while_condition_type()
    if rc != 0 { return rc }

    rc = test_break_outside_loop()
    if rc != 0 { return rc }

    rc = test_function_call()
    if rc != 0 { return rc }

    rc = test_function_wrong_arg_type()
    if rc != 0 { return rc }

    rc = test_function_wrong_arg_count()
    if rc != 0 { return rc }

    rc = test_function_declaration()
    if rc != 0 { return rc }

    rc = test_struct_declaration_and_field()
    if rc != 0 { return rc }

    rc = test_struct_unknown_field()
    if rc != 0 { return rc }

    rc = test_user_function_call()
    if rc != 0 { return rc }

    // 9.10 Phase A tests
    rc = test_expanded_builtins()
    if rc != 0 { return rc }

    rc = test_string_methods()
    if rc != 0 { return rc }

    rc = test_integer_methods()
    if rc != 0 { return rc }

    rc = test_float_methods()
    if rc != 0 { return rc }

    rc = test_array_methods()
    if rc != 0 { return rc }

    rc = test_generic_apply_list()
