    let err_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_msg.1)
    let r_err_call: (TypeChecker, ExprId) = add_call_expr(tc, r_err_callee.1, err_args, 1)
    tc = r_err_call.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_err_call.1)
    tc = re2.0
    if not expect_kind(re2.1, "Result", "Err(\"msg\") → Result") { return 31 }
    let err_inner: KlarType = unwrap_result_err(tc, re2.1)
    if not expect_type(err_inner, type_string(), "Err(\"msg\") err type is string") { return 31 }

    if not expect_ok(tc, "Ok/Err constructors") { return 31 }
    return 0
}

