    tc = r_ok_callee.0
    let r_val: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_val.0
    let ok_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_val.1)
    let r_ok_call: (TypeChecker, ExprId) = add_call_expr(tc, r_ok_callee.1, ok_args, 1)
    tc = r_ok_call.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_ok_call.1)
    tc = re1.0
    if not expect_kind(re1.1, "Result", "Ok(42) → Result") { return 31 }
    let ok_inner: KlarType = unwrap_result_ok(tc, re1.1)
    if not expect_type(ok_inner, type_i32(), "Ok(42) ok type is i32") { return 31 }

    // Err("msg") → Result#[?, string]
    let r_err_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "Err")
    tc = r_err_callee.0
    let r_msg: (TypeChecker, ExprId) = add_str_expr(tc, "error")
