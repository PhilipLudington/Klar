fn test_trait_impl_method_body_checked() -> i32 {
    // Verify that impl method bodies are type-checked
    // impl Foo { fn bad(self) -> i32 { return "hello" } } → error
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Struct Foo
    let t_i32: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32.0
    let fs: i32 = tc.extra_struct_fields.len()
    tc.extra_struct_fields.push(StructField { field_name: "x", type_expr: t_i32.1, span: s() })

    let ds: i32 = tc.decls.len()
    tc.decls.push(Decl::StructDecl(StructDeclData {
        struct_name: "Foo",
        generics_start: 0, generics_count: 0,
        fields_start: fs, fields_count: 1,
        is_pub: true, is_extern: false, is_packed: false,
        span: s(),
    }))

    // impl Foo { fn bad(self) -> i32 { return "hello" } }
    let impl_ret: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = impl_ret.0
    let self_te: (TypeChecker, TypeExprId) = add_type_named(tc, "Foo")
    tc = self_te.0
    let ps: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "self", type_expr: self_te.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    // Body: return "hello" (should error: expected i32)
    let r_str: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_str.0
    let r_ret: (TypeChecker, StmtId) = add_return_stmt(tc, r_str.1)
    tc = r_ret.0
    let bs: i32 = tc.extra_stmt_ids.len()
    tc.extra_stmt_ids.push(r_ret.1)

    let mi: i32 = tc.decls.len()
    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "bad",
        generics_start: 0, generics_count: 0,
        params_start: ps, params_count: 1,
        return_type: impl_ret.1,
        body_start: bs, body_count: 1,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    tc.decls.push(Decl::ImplDecl(ImplDeclData {
        target_type: "Foo",
        impl_trait: "",
        generics_start: 0, generics_count: 0,
        methods_start: mi, methods_count: 1,
        assoc_types_start: 0, assoc_types_count: 0,
        span: s(),
    }))

    let dc: i32 = tc.decls.len() - ds
    tc = check_module(tc, ds, dc)
    if not expect_errors(tc, 1, "impl method body type error") { return 69 }

    return 0
}

fn test_trait_inheritance_registered() -> i32 {
    // Register a trait with a parent count > 0 to verify super_traits_count is stored
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Trait SubTrait (claims 1 parent — we just check the count is recorded)
    let ds: i32 = tc.decls.len()
    tc.decls.push(Decl::TraitDecl(TraitDeclData {
        trait_name: "SubTrait",
        generics_start: 0, generics_count: 0,
        parents_start: 0, parents_count: 1,
        methods_start: 0, methods_count: 0,
        assoc_types_start: 0, assoc_types_count: 0,
        is_pub: false, span: s(),
    }))

    tc = register_declarations(tc, ds, 1)
    if not expect_ok(tc, "register SubTrait with parent") { return 70 }

    let opt: ?KlarType = tc.trait_types.get("SubTrait")
    match opt {
        Some(t) => {
            let td: TraitData = tc.type_traits[t.payload]
            if td.super_traits_count != 1 {
                println("FAIL: test_trait_inheritance — expected super_traits_count 1, got " +
                    td.super_traits_count.to_string().as_str())
                return 70
            }
        }
        None => {
            println("FAIL: test_trait_inheritance — SubTrait not found")
            return 70
        }
    }

    return 0
}

fn test_multiple_bounds() -> i32 {
    // TypeVar T with bounds [Eq, Clone] — both trait methods available
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Get Eq and Clone trait indices (they are sequential from register_builtin_traits)
    let eq_opt: ?KlarType = tc.trait_types.get("Eq")
    var eq_idx: i32 = 0
    match eq_opt {
        Some(t) => { eq_idx = t.payload }
        None => { return 71 }
    }

    let clone_opt: ?KlarType = tc.trait_types.get("Clone")
    var clone_idx: i32 = 0
    match clone_opt {
        Some(t) => { clone_idx = t.payload }
        None => { return 71 }
    }

    // For multiple bounds, they need to be in sequential trait indices.
    // Since Eq is registered first, its index should be less than Clone's.
    // We can only use contiguous bounds_start..bounds_start+count.
    // If Eq=0 and Clone=2, we can't do [0,2] as contiguous range.
    // So let's test with Ordered (which has 4 methods: lt,le,gt,ge) — that's index 1.
    // Eq is index 0, Ordered is index 1 — they ARE contiguous!
    let tvr: (TypeChecker, KlarType) = make_type_var_with_bounds(tc, 0, "T", eq_idx, 2)
    tc = tvr.0

    tc.push_scope()
    tc.define("a", SymbolInfo {
        sym_name: "a", sym_type: tvr.1, mutable: false, kind: SymbolKind::Variable,
    })

    // a.eq(...) should work through Eq bound
    let r_a1: (TypeChecker, ExprId) = add_ident_expr(tc, "a")
    tc = r_a1.0
    let r_eq: (TypeChecker, ExprId) = add_method_call_expr(tc, r_a1.1, "eq", 0, 0)
    tc = r_eq.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_eq.1)
    tc = re1.0
    if not expect_ok(tc, "a.eq() with T: Eq + Ordered") { return 71 }
    if not expect_type(re1.1, type_bool(), "eq() returns bool") { return 71 }

    // a.lt(...) should work through Ordered bound
    let r_a2: (TypeChecker, ExprId) = add_ident_expr(tc, "a")
    tc = r_a2.0
    let r_lt: (TypeChecker, ExprId) = add_method_call_expr(tc, r_a2.1, "lt", 0, 0)
    tc = r_lt.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_lt.1)
    tc = re2.0
    if not expect_ok(tc, "a.lt() with T: Eq + Ordered") { return 71 }
    if not expect_type(re2.1, type_bool(), "lt() returns bool") { return 71 }

    tc.pop_scope()
    return 0
}

