fn test_function_declaration() -> i32 {
    // Build AST for:
    //   fn add(a: i32, b: i32) -> i32 { return a + b }
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Type expressions: i32, i32, i32
    let t1: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t1.0
    let t2: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t2.0
    let t3: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t3.0

    // Params: a: i32, b: i32
    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "a", type_expr: t1.1, default_value: no_expr(), is_mut: false, span: s(),
    })
    tc.extra_params.push(FnParam {
        param_name: "b", type_expr: t2.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    // Body: return a + b
    let r_a: (TypeChecker, ExprId) = add_ident_expr(tc, "a")
    tc = r_a.0
    let r_b: (TypeChecker, ExprId) = add_ident_expr(tc, "b")
    tc = r_b.0
    let r_add: (TypeChecker, ExprId) = add_binary_expr(tc, r_a.1, BinaryOp::Add, r_b.1)
    tc = r_add.0
    let r_ret: (TypeChecker, StmtId) = add_return_stmt(tc, r_add.1)
    tc = r_ret.0
    let body_start: i32 = tc.extra_stmt_ids.len()
    tc.extra_stmt_ids.push(r_ret.1)

    // Function declaration
    let decl_idx: i32 = tc.decls.len()
    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "add",
        generics_start: 0, generics_count: 0,
        params_start: params_start, params_count: 2,
        return_type: t3.1,
        body_start: body_start, body_count: 1,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    // Run full pipeline
    tc = check_module(tc, decl_idx, 1)
    if not expect_ok(tc, "fn add(a: i32, b: i32) -> i32") { return 17 }

    // Verify add is callable
    let found: ?SymbolInfo = lookup(tc, "add")
    match found {
        Some(info) => {
            if info.sym_type.payload < 0 {
                println("FAIL: add should have valid function payload")
                return 17
            }
        }
        None => {
            println("FAIL: add not found after declaration")
            return 17
        }
    }

    return 0
}

fn test_struct_declaration_and_field() -> i32 {
    // Build AST for:
    //   struct Point { x: i32, y: i32 }
    //   fn get_x(p: Point) -> i32 { return p.x }
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Type expressions
    let t_i32_1: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_1.0
    let t_i32_2: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_2.0
    let t_point: (TypeChecker, TypeExprId) = add_type_named(tc, "Point")
    tc = t_point.0
    let t_i32_ret: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_ret.0

    // Struct fields
    let fields_start: i32 = tc.extra_struct_fields.len()
    tc.extra_struct_fields.push(StructField {
        field_name: "x", type_expr: t_i32_1.1, span: s(),
    })
    tc.extra_struct_fields.push(StructField {
        field_name: "y", type_expr: t_i32_2.1, span: s(),
    })

    // Struct decl
    let decl_start: i32 = tc.decls.len()
    tc.decls.push(Decl::StructDecl(StructDeclData {
        struct_name: "Point",
        generics_start: 0, generics_count: 0,
        fields_start: fields_start, fields_count: 2,
        is_pub: true, is_extern: false, is_packed: false,
        span: s(),
    }))

    // Function: fn get_x(p: Point) -> i32 { return p.x }
    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "p", type_expr: t_point.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    // Body: return p.x
    let r_p: (TypeChecker, ExprId) = add_ident_expr(tc, "p")
    tc = r_p.0
    let r_px: (TypeChecker, ExprId) = add_field_expr(tc, r_p.1, "x")
    tc = r_px.0
    let r_ret: (TypeChecker, StmtId) = add_return_stmt(tc, r_px.1)
    tc = r_ret.0
    let body_start: i32 = tc.extra_stmt_ids.len()
    tc.extra_stmt_ids.push(r_ret.1)

    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "get_x",
        generics_start: 0, generics_count: 0,
        params_start: params_start, params_count: 1,
        return_type: t_i32_ret.1,
        body_start: body_start, body_count: 1,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    // Run checker
    tc = check_module(tc, decl_start, 2)
    if not expect_ok(tc, "struct Point + fn get_x") { return 18 }

    return 0
}

fn test_struct_unknown_field() -> i32 {
    // struct Point { x: i32, y: i32 }
    // fn bad(p: Point) -> i32 { return p.z }  ← error
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let t_i32_1: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_1.0
    let t_i32_2: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_2.0
    let t_point: (TypeChecker, TypeExprId) = add_type_named(tc, "Point")
    tc = t_point.0
    let t_i32_ret: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32_ret.0

    let fields_start: i32 = tc.extra_struct_fields.len()
    tc.extra_struct_fields.push(StructField { field_name: "x", type_expr: t_i32_1.1, span: s() })
    tc.extra_struct_fields.push(StructField { field_name: "y", type_expr: t_i32_2.1, span: s() })

    let decl_start: i32 = tc.decls.len()
    tc.decls.push(Decl::StructDecl(StructDeclData {
        struct_name: "Point",
        generics_start: 0, generics_count: 0,
        fields_start: fields_start, fields_count: 2,
        is_pub: true, is_extern: false, is_packed: false,
        span: s(),
    }))

    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "p", type_expr: t_point.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    // Body: return p.z  (unknown field)
    let r_p: (TypeChecker, ExprId) = add_ident_expr(tc, "p")
    tc = r_p.0
    let r_pz: (TypeChecker, ExprId) = add_field_expr(tc, r_p.1, "z")
    tc = r_pz.0
    let r_ret: (TypeChecker, StmtId) = add_return_stmt(tc, r_pz.1)
    tc = r_ret.0
    let body_start: i32 = tc.extra_stmt_ids.len()
    tc.extra_stmt_ids.push(r_ret.1)

    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "bad",
        generics_start: 0, generics_count: 0,
        params_start: params_start, params_count: 1,
        return_type: t_i32_ret.1,
        body_start: body_start, body_count: 1,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    tc = check_module(tc, decl_start, 2)
    if not expect_errors(tc, 1, "p.z → unknown field error") { return 19 }

    return 0
}

fn test_user_function_call() -> i32 {
    // fn add(a: i32, b: i32) -> i32 { return a + b }
    // fn main() -> i32 { let x: i32 = add(1, 2); return x }
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Type exprs
    let t1: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t1.0
    let t2: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t2.0
    let t3: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t3.0
    let t4: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t4.0
    let t5: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t5.0

    // add params
    let add_params: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam { param_name: "a", type_expr: t1.1, default_value: no_expr(), is_mut: false, span: s() })
    tc.extra_params.push(FnParam { param_name: "b", type_expr: t2.1, default_value: no_expr(), is_mut: false, span: s() })

    // add body: return a + b
    let r_a: (TypeChecker, ExprId) = add_ident_expr(tc, "a")
    tc = r_a.0
    let r_b: (TypeChecker, ExprId) = add_ident_expr(tc, "b")
    tc = r_b.0
    let r_plus: (TypeChecker, ExprId) = add_binary_expr(tc, r_a.1, BinaryOp::Add, r_b.1)
    tc = r_plus.0
    let r_ret1: (TypeChecker, StmtId) = add_return_stmt(tc, r_plus.1)
    tc = r_ret1.0
    let add_body: i32 = tc.extra_stmt_ids.len()
    tc.extra_stmt_ids.push(r_ret1.1)

    let decl_start: i32 = tc.decls.len()
    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "add",
        generics_start: 0, generics_count: 0,
        params_start: add_params, params_count: 2,
        return_type: t3.1,
        body_start: add_body, body_count: 1,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    // main body: let x: i32 = add(1, 2); return x
    let r_add_ident: (TypeChecker, ExprId) = add_ident_expr(tc, "add")
    tc = r_add_ident.0
    let r_arg1: (TypeChecker, ExprId) = add_int_expr(tc, "1")
    tc = r_arg1.0
    let r_arg2: (TypeChecker, ExprId) = add_int_expr(tc, "2")
    tc = r_arg2.0
    let call_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_arg1.1)
    tc.extra_expr_ids.push(r_arg2.1)
    let r_call: (TypeChecker, ExprId) = add_call_expr(tc, r_add_ident.1, call_args, 2)
    tc = r_call.0

    let r_let: (TypeChecker, StmtId) = add_let_stmt(tc, "x", t4.1, r_call.1)
    tc = r_let.0

    let r_x: (TypeChecker, ExprId) = add_ident_expr(tc, "x")
    tc = r_x.0
    let r_ret2: (TypeChecker, StmtId) = add_return_stmt(tc, r_x.1)
    tc = r_ret2.0

    let main_body: i32 = tc.extra_stmt_ids.len()
    tc.extra_stmt_ids.push(r_let.1)
    tc.extra_stmt_ids.push(r_ret2.1)

    tc.decls.push(Decl::Function(FunctionDeclData {
        fn_name: "test_main",
        generics_start: 0, generics_count: 0,
        params_start: tc.extra_params.len(), params_count: 0,
        return_type: t5.1,
        body_start: main_body, body_count: 2,
        is_pub: false, is_extern: false, is_unsafe: false,
        is_comptime: false, is_variadic: false,
        span: s(),
    }))

    tc = check_module(tc, decl_start, 2)
    if not expect_ok(tc, "fn add + fn main calling add") { return 20 }

    return 0
}

// ─── 9.10 Phase A Tests ─────────────────────────────────────────────

fn test_expanded_builtins() -> i32 {
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // assert_eq(1, 2) → void (no error, polymorphic)
    let r_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "assert_eq")
    tc = r_callee.0
    let r_a1: (TypeChecker, ExprId) = add_int_expr(tc, "1")
    tc = r_a1.0
    let r_a2: (TypeChecker, ExprId) = add_int_expr(tc, "2")
    tc = r_a2.0
    let args_s: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_a1.1)
    tc.extra_expr_ids.push(r_a2.1)
    let r_call: (TypeChecker, ExprId) = add_call_expr(tc, r_callee.1, args_s, 2)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_type(re.1, type_void(), "assert_eq returns void") { return 21 }
    if not expect_ok(tc, "assert_eq(1, 2)") { return 21 }

    // panic("msg") → never
    let r_panic: (TypeChecker, ExprId) = add_ident_expr(tc, "panic")
    tc = r_panic.0
    let r_msg: (TypeChecker, ExprId) = add_str_expr(tc, "error")
    tc = r_msg.0
    let args_p: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_msg.1)
    let r_call2: (TypeChecker, ExprId) = add_call_expr(tc, r_panic.1, args_p, 1)
    tc = r_call2.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_call2.1)
    tc = re2.0
    if not expect_type(re2.1, type_never(), "panic returns never") { return 21 }

    // exit(0) → never
    let r_exit: (TypeChecker, ExprId) = add_ident_expr(tc, "exit")
    tc = r_exit.0
    let r_code: (TypeChecker, ExprId) = add_int_expr(tc, "0")
    tc = r_code.0
    let args_e: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_code.1)
    let r_call3: (TypeChecker, ExprId) = add_call_expr(tc, r_exit.1, args_e, 1)
    tc = r_call3.0
    let re3: (TypeChecker, KlarType) = check_expr(tc, r_call3.1)
    tc = re3.0
    if not expect_type(re3.1, type_never(), "exit returns never") { return 21 }

    // sqrt(1.0) → f64
    let r_sqrt: (TypeChecker, ExprId) = add_ident_expr(tc, "sqrt")
    tc = r_sqrt.0
    let r_fv: (TypeChecker, ExprId) = add_float_expr(tc, "1.0")
    tc = r_fv.0
    let args_sq: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_fv.1)
    let r_call4: (TypeChecker, ExprId) = add_call_expr(tc, r_sqrt.1, args_sq, 1)
    tc = r_call4.0
    let re4: (TypeChecker, KlarType) = check_expr(tc, r_call4.1)
    tc = re4.0
    if not expect_type(re4.1, type_f64(), "sqrt returns f64") { return 21 }

    // readline() → string
    let r_rl: (TypeChecker, ExprId) = add_ident_expr(tc, "readline")
    tc = r_rl.0
    let r_call5: (TypeChecker, ExprId) = add_call_expr(tc, r_rl.1, 0, 0)
    tc = r_call5.0
    let re5: (TypeChecker, KlarType) = check_expr(tc, r_call5.1)
    tc = re5.0
    if not expect_type(re5.1, type_string(), "readline returns string") { return 21 }

    if not expect_ok(tc, "expanded builtins") { return 21 }
    return 0
}

fn test_string_methods() -> i32 {
    var tc: TypeChecker = TypeChecker.new()

    // "hello".len() → i32
    let r_s: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_s.0
    let r_len: (TypeChecker, ExprId) = add_method_call_expr(tc, r_s.1, "len", 0, 0)
    tc = r_len.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_len.1)
    tc = re1.0
    if not expect_type(re1.1, type_i32(), "string.len() → i32") { return 22 }

    // "hello".is_empty() → bool
    let r_s2: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_s2.0
    let r_ie: (TypeChecker, ExprId) = add_method_call_expr(tc, r_s2.1, "is_empty", 0, 0)
    tc = r_ie.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_ie.1)
    tc = re2.0
    if not expect_type(re2.1, type_bool(), "string.is_empty() → bool") { return 22 }

    // "hello".contains("ell") → bool
    let r_s3: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_s3.0
    let r_arg: (TypeChecker, ExprId) = add_str_expr(tc, "ell")
    tc = r_arg.0
    let c_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_arg.1)
    let r_con: (TypeChecker, ExprId) = add_method_call_expr(tc, r_s3.1, "contains", c_args, 1)
    tc = r_con.0
    let re3: (TypeChecker, KlarType) = check_expr(tc, r_con.1)
    tc = re3.0
    if not expect_type(re3.1, type_bool(), "string.contains() → bool") { return 22 }

    // "hello".trim() → string
    let r_s4: (TypeChecker, ExprId) = add_str_expr(tc, " hello ")
    tc = r_s4.0
    let r_trim: (TypeChecker, ExprId) = add_method_call_expr(tc, r_s4.1, "trim", 0, 0)
    tc = r_trim.0
    let re4: (TypeChecker, KlarType) = check_expr(tc, r_trim.1)
    tc = re4.0
    if not expect_type(re4.1, type_string(), "string.trim() → string") { return 22 }

    // "hello".split(",") → List#[string]
    let r_s5: (TypeChecker, ExprId) = add_str_expr(tc, "a,b")
    tc = r_s5.0
    let r_delim: (TypeChecker, ExprId) = add_str_expr(tc, ",")
    tc = r_delim.0
    let sp_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_delim.1)
    let r_split: (TypeChecker, ExprId) = add_method_call_expr(tc, r_s5.1, "split", sp_args, 1)
    tc = r_split.0
    let re5: (TypeChecker, KlarType) = check_expr(tc, r_split.1)
    tc = re5.0
    if not expect_kind(re5.1, "ListType", "string.split() → List") { return 22 }

    // "hello".byte_at(0) → u8
    let r_s6: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_s6.0
    let r_idx: (TypeChecker, ExprId) = add_int_expr(tc, "0")
    tc = r_idx.0
    let ba_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_idx.1)
    let r_ba: (TypeChecker, ExprId) = add_method_call_expr(tc, r_s6.1, "byte_at", ba_args, 1)
    tc = r_ba.0
    let re6: (TypeChecker, KlarType) = check_expr(tc, r_ba.1)
    tc = re6.0
    if not expect_type(re6.1, type_u8(), "string.byte_at() → u8") { return 22 }

    if not expect_ok(tc, "string methods") { return 22 }
    return 0
}

