fn test_if_expr_condition_error() -> i32 {
    // if 42 { 1 } else { 2 } → error (condition not bool)
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let r_cond: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_cond.0
    let r_then: (TypeChecker, ExprId) = add_int_expr(tc, "1")
    tc = r_then.0
    let r_else: (TypeChecker, ExprId) = add_int_expr(tc, "2")
    tc = r_else.0

    let if_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::IfExpr(IfExprData {
        condition: r_cond.1,
        then_body: r_then.1,
        else_body: r_else.1,
        span: s(),
    }))
    let if_eid: ExprId = ExprId { id: if_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, if_eid)
    tc = re.0
    if not expect_errors(tc, 1, "if expr non-bool condition → error") { return 76 }

    return 0
}

fn test_match_expr_basic() -> i32 {
    // match x { 1 => { "one" }, _ => { "other" } } → string
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Define x: i32
    tc.push_scope()
    tc.define("x", SymbolInfo {
        sym_name: "x", sym_type: type_i32(), mutable: false, kind: SymbolKind::Variable,
    })

    // Subject: x
    let r_subj: (TypeChecker, ExprId) = add_ident_expr(tc, "x")
    tc = r_subj.0

    // Arm 1: wildcard pattern => "one"
    let wild_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::Wildcard(WildcardData { span: s() }))
    let r_body1: (TypeChecker, ExprId) = add_str_expr(tc, "one")
    tc = r_body1.0

    // Arm 2: wildcard => "other"
    let wild2_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::Wildcard(WildcardData { span: s() }))
    let r_body2: (TypeChecker, ExprId) = add_str_expr(tc, "other")
    tc = r_body2.0

    // Build match arms
    let arms_start: i32 = tc.extra_match_arms.len()
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: wild_pid },
        guard: no_expr(),
        body: r_body1.1,
        span: s(),
    })
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: wild2_pid },
        guard: no_expr(),
        body: r_body2.1,
        span: s(),
    })

    let match_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::MatchExpr(MatchExprData {
        subject: r_subj.1,
        arms_start: arms_start,
        arms_count: 2,
        span: s(),
    }))
    let match_eid: ExprId = ExprId { id: match_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, match_eid)
    tc = re.0
    if not expect_ok(tc, "match expr basic") { return 77 }
    if not expect_type(re.1, type_string(), "match expr → string") { return 77 }

    tc.pop_scope()
    return 0
}

fn test_match_optional_pattern() -> i32 {
    // match opt { Some(val) => { val }, None => { 0 } }
    // opt: ?i32 → val should be i32
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Build ?i32 type
    let opt_r: (TypeChecker, KlarType) = make_optional_type(tc, type_i32())
    tc = opt_r.0
    let opt_type: KlarType = opt_r.1

    tc.push_scope()
    tc.define("opt", SymbolInfo {
        sym_name: "opt", sym_type: opt_type, mutable: false, kind: SymbolKind::Variable,
    })

    // Subject: opt
    let r_subj: (TypeChecker, ExprId) = add_ident_expr(tc, "opt")
    tc = r_subj.0

    // Arm 1: Some(val) => val
    // Inner pattern: binding "val"
    let inner_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::BindingPat(BindingPatData {
        binding_name: "val", is_mut: false, span: s(),
    }))
    let inner_start: i32 = tc.extra_pattern_ids.len()
    tc.extra_pattern_ids.push(PatternId { id: inner_pid })

    let some_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::VariantPat(VariantPatData {
        type_expr: no_type_expr(),
        variant_name: "Some",
        fields_start: inner_start,
        fields_count: 1,
        span: s(),
    }))

    // Body: identifier "val" (should be i32 from pattern binding)
    let r_val: (TypeChecker, ExprId) = add_ident_expr(tc, "val")
    tc = r_val.0

    // Arm 2: None => 0
    let none_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::VariantPat(VariantPatData {
        type_expr: no_type_expr(),
        variant_name: "None",
        fields_start: 0,
        fields_count: 0,
        span: s(),
    }))
    let r_zero: (TypeChecker, ExprId) = add_int_expr(tc, "0")
    tc = r_zero.0

    // Build match arms
    let arms_start: i32 = tc.extra_match_arms.len()
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: some_pid },
        guard: no_expr(),
        body: r_val.1,
        span: s(),
    })
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: none_pid },
        guard: no_expr(),
        body: r_zero.1,
        span: s(),
    })

    let match_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::MatchExpr(MatchExprData {
        subject: r_subj.1,
        arms_start: arms_start,
        arms_count: 2,
        span: s(),
    }))
    let match_eid: ExprId = ExprId { id: match_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, match_eid)
    tc = re.0
    if not expect_ok(tc, "match ?i32 with Some(val)/None") { return 78 }
    // First arm body is "val" which should resolve to i32 (inner of ?i32)
    if not expect_type(re.1, type_i32(), "match ?i32 result → i32") { return 78 }

    tc.pop_scope()
    return 0
}

fn test_match_result_pattern() -> i32 {
    // match res { Ok(v) => { v }, Err(_) => { -1 } }
    // res: Result#[i32, string] → both arms yield i32
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Build Result#[i32, string] type
    let res_r: (TypeChecker, KlarType) = make_result_type(tc, type_i32(), type_string())
    tc = res_r.0
    let res_type: KlarType = res_r.1

    tc.push_scope()
    tc.define("res", SymbolInfo {
        sym_name: "res", sym_type: res_type, mutable: false, kind: SymbolKind::Variable,
    })

    // Subject: res
    let r_subj: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_subj.0

    // Arm 1: Ok(v) => v (i32)
    let ok_inner_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::BindingPat(BindingPatData {
        binding_name: "v", is_mut: false, span: s(),
    }))
    let ok_fields_start: i32 = tc.extra_pattern_ids.len()
    tc.extra_pattern_ids.push(PatternId { id: ok_inner_pid })

    let ok_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::VariantPat(VariantPatData {
        type_expr: no_type_expr(),
        variant_name: "Ok",
        fields_start: ok_fields_start,
        fields_count: 1,
        span: s(),
    }))

    let r_v: (TypeChecker, ExprId) = add_ident_expr(tc, "v")
    tc = r_v.0

    // Arm 2: Err(_) => -1 (i32, consistent with Ok arm)
    let err_wild_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::Wildcard(WildcardData { span: s() }))
    let err_fields_start: i32 = tc.extra_pattern_ids.len()
    tc.extra_pattern_ids.push(PatternId { id: err_wild_pid })

    let err_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::VariantPat(VariantPatData {
        type_expr: no_type_expr(),
        variant_name: "Err",
        fields_start: err_fields_start,
        fields_count: 1,
        span: s(),
    }))

    let r_default: (TypeChecker, ExprId) = add_int_expr(tc, "0")
    tc = r_default.0

    // Build match arms
    let arms_start: i32 = tc.extra_match_arms.len()
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: ok_pid },
        guard: no_expr(),
        body: r_v.1,
        span: s(),
    })
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: err_pid },
        guard: no_expr(),
        body: r_default.1,
        span: s(),
    })

    let match_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::MatchExpr(MatchExprData {
        subject: r_subj.1,
        arms_start: arms_start,
        arms_count: 2,
        span: s(),
    }))
    let match_eid: ExprId = ExprId { id: match_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, match_eid)
    tc = re.0
    if not expect_ok(tc, "match Result#[i32, string] with Ok/Err") { return 79 }
    // Both arms yield i32
    if not expect_type(re.1, type_i32(), "Ok(v) body → i32") { return 79 }

    tc.pop_scope()
    return 0
}

fn test_match_binding_pattern() -> i32 {
    // match x { val => { val + 1 } } — binding pattern gets subject type
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    tc.push_scope()
    tc.define("x", SymbolInfo {
        sym_name: "x", sym_type: type_i32(), mutable: false, kind: SymbolKind::Variable,
    })

    let r_subj: (TypeChecker, ExprId) = add_ident_expr(tc, "x")
    tc = r_subj.0

    // Binding pattern: val
    let bind_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::BindingPat(BindingPatData {
        binding_name: "val", is_mut: false, span: s(),
    }))

    // Body: val + 1
    let r_val: (TypeChecker, ExprId) = add_ident_expr(tc, "val")
    tc = r_val.0
    let r_one: (TypeChecker, ExprId) = add_int_expr(tc, "1")
    tc = r_one.0
    let r_add: (TypeChecker, ExprId) = add_binary_expr(tc, r_val.1, BinaryOp::Add, r_one.1)
    tc = r_add.0

    let arms_start: i32 = tc.extra_match_arms.len()
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: bind_pid },
        guard: no_expr(),
        body: r_add.1,
        span: s(),
    })

    let match_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::MatchExpr(MatchExprData {
        subject: r_subj.1,
        arms_start: arms_start,
        arms_count: 1,
        span: s(),
    }))
    let match_eid: ExprId = ExprId { id: match_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, match_eid)
    tc = re.0
    if not expect_ok(tc, "match binding pattern val + 1") { return 80 }
    if not expect_type(re.1, type_i32(), "binding val + 1 → i32") { return 80 }

    tc.pop_scope()
    return 0
}

fn test_if_expr_mismatched_branches() -> i32 {
    // if true { 1 } else { "hello" } → error (branch type mismatch)
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let r_cond: (TypeChecker, ExprId) = add_bool_expr(tc, true)
    tc = r_cond.0
    let r_then: (TypeChecker, ExprId) = add_int_expr(tc, "1")
    tc = r_then.0
    let r_else: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_else.0

    let if_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::IfExpr(IfExprData {
        condition: r_cond.1,
        then_body: r_then.1,
        else_body: r_else.1,
        span: s(),
    }))
    let if_eid: ExprId = ExprId { id: if_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, if_eid)
    tc = re.0
    if not expect_errors(tc, 1, "if expr mismatched branches → error") { return 81 }

    return 0
}

fn test_match_expr_mismatched_arms() -> i32 {
    // match x { _ => { 1 }, _ => { "hello" } } → error (arm type mismatch)
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    tc.push_scope()
    tc.define("x", SymbolInfo {
        sym_name: "x", sym_type: type_i32(), mutable: false, kind: SymbolKind::Variable,
    })

    let r_subj: (TypeChecker, ExprId) = add_ident_expr(tc, "x")
    tc = r_subj.0

    // Arm 1: _ => 1 (i32)
    let w1: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::Wildcard(WildcardData { span: s() }))
    let r_body1: (TypeChecker, ExprId) = add_int_expr(tc, "1")
    tc = r_body1.0

    // Arm 2: _ => "hello" (string)
    let w2: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::Wildcard(WildcardData { span: s() }))
    let r_body2: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_body2.0

    let arms_start: i32 = tc.extra_match_arms.len()
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: w1 },
        guard: no_expr(),
        body: r_body1.1,
        span: s(),
    })
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: w2 },
        guard: no_expr(),
        body: r_body2.1,
        span: s(),
    })

    let match_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::MatchExpr(MatchExprData {
        subject: r_subj.1,
        arms_start: arms_start,
        arms_count: 2,
        span: s(),
    }))
    let match_eid: ExprId = ExprId { id: match_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, match_eid)
    tc = re.0
    if not expect_errors(tc, 1, "match expr mismatched arms → error") { return 82 }

    tc.pop_scope()
    return 0
}

fn test_match_expr_guard() -> i32 {
    // match x { val when val > 0 => { val } } — valid guard
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    tc.push_scope()
    tc.define("x", SymbolInfo {
        sym_name: "x", sym_type: type_i32(), mutable: false, kind: SymbolKind::Variable,
    })

    let r_subj: (TypeChecker, ExprId) = add_ident_expr(tc, "x")
    tc = r_subj.0

    // Binding pattern: val
    let bind_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::BindingPat(BindingPatData {
        binding_name: "val", is_mut: false, span: s(),
    }))

    // Guard: true (bool — valid)
    let r_guard: (TypeChecker, ExprId) = add_bool_expr(tc, true)
    tc = r_guard.0

    // Body: val
    let r_val: (TypeChecker, ExprId) = add_ident_expr(tc, "val")
    tc = r_val.0

    let arms_start: i32 = tc.extra_match_arms.len()
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: bind_pid },
        guard: r_guard.1,
        body: r_val.1,
        span: s(),
    })

    let match_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::MatchExpr(MatchExprData {
        subject: r_subj.1,
        arms_start: arms_start,
        arms_count: 1,
        span: s(),
    }))
    let match_eid: ExprId = ExprId { id: match_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, match_eid)
    tc = re.0
    if not expect_ok(tc, "match with valid bool guard") { return 83 }
    if not expect_type(re.1, type_i32(), "guarded match → i32") { return 83 }

    tc.pop_scope()
    return 0
}

