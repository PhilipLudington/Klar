fn test_list_methods() -> i32 {
    // Create a List#[i32] variable and test method types
    var tc: TypeChecker = TypeChecker.new()
    tc.push_scope()

    // Build List#[i32] type programmatically
    let lr: (TypeChecker, KlarType) = make_list_type(tc, type_i32())
    tc = lr.0
    let list_type: KlarType = lr.1

    tc.define("items", SymbolInfo {
        sym_name: "items", sym_type: list_type, mutable: true, kind: SymbolKind::Variable,
    })

    // items.len() → i32
    let r_items: (TypeChecker, ExprId) = add_ident_expr(tc, "items")
    tc = r_items.0
    let r_len: (TypeChecker, ExprId) = add_method_call_expr(tc, r_items.1, "len", 0, 0)
    tc = r_len.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_len.1)
    tc = re1.0
    if not expect_type(re1.1, type_i32(), "List.len() → i32") { return 28 }

    // items.push(42) → void
    let r_items2: (TypeChecker, ExprId) = add_ident_expr(tc, "items")
    tc = r_items2.0
    let r_val: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_val.0
    let push_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_val.1)
    let r_push: (TypeChecker, ExprId) = add_method_call_expr(tc, r_items2.1, "push", push_args, 1)
    tc = r_push.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_push.1)
    tc = re2.0
    if not expect_type(re2.1, type_void(), "List.push() → void") { return 28 }

    // items.pop() → ?i32
    let r_items3: (TypeChecker, ExprId) = add_ident_expr(tc, "items")
    tc = r_items3.0
    let r_pop: (TypeChecker, ExprId) = add_method_call_expr(tc, r_items3.1, "pop", 0, 0)
    tc = r_pop.0
    let re3: (TypeChecker, KlarType) = check_expr(tc, r_pop.1)
    tc = re3.0
    if not expect_kind(re3.1, "Optional", "List.pop() → Optional") { return 28 }

    // items.contains(1) → bool
    let r_items4: (TypeChecker, ExprId) = add_ident_expr(tc, "items")
    tc = r_items4.0
    let r_cv: (TypeChecker, ExprId) = add_int_expr(tc, "1")
    tc = r_cv.0
    let con_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_cv.1)
    let r_con: (TypeChecker, ExprId) = add_method_call_expr(tc, r_items4.1, "contains", con_args, 1)
    tc = r_con.0
    let re4: (TypeChecker, KlarType) = check_expr(tc, r_con.1)
    tc = re4.0
    if not expect_type(re4.1, type_bool(), "List.contains() → bool") { return 28 }

    if not expect_ok(tc, "list methods") { return 28 }
    return 0
}

