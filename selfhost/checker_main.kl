    tc = r_bad.0
    let r_while2: (TypeChecker, StmtId) = add_while_stmt(tc, r_bad.1, 0, 0)
    tc = r_while2.0
    tc = check_stmt(tc, r_while2.1)
    if not expect_errors(tc, 1, "while 42 → error") { return 12 }

    return 0
}

