// ─── 9.10.3 Phase B: Closure, If Expr, Match Expr Tests ─────────────

fn test_closure_basic() -> i32 {
    // Closure: |x: i32| -> i32 { return x + 1 }
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // Build closure: |x: i32| -> i32 { <body> }
    // Parameter: x: i32
    let t_i32: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = t_i32.0
    let params_start: i32 = tc.extra_params.len()
    tc.extra_params.push(FnParam {
        param_name: "x", type_expr: t_i32.1, default_value: no_expr(), is_mut: false, span: s(),
    })

    // Return type: i32
    let ret_te: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = ret_te.0

    // Body: just an int literal (simplified — body is an expression)
    let r_body: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_body.0

    // Build closure expression
    let closure_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::Closure(ClosureData {
        params_start: params_start,
        params_count: 1,
        return_type: ret_te.1,
        body: r_body.1,
        span: s(),
    }))
    let closure_eid: ExprId = ExprId { id: closure_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, closure_eid)
    tc = re.0
    if not expect_ok(tc, "closure |x: i32| -> i32") { return 73 }
    if not expect_kind(re.1, "Function", "closure type is Function") { return 73 }

    return 0
}

