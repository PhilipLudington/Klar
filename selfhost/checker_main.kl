fn test_closure_no_params() -> i32 {
    // Closure: || -> i32 { 42 }
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let ret_te: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = ret_te.0

    let r_body: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_body.0

    let closure_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::Closure(ClosureData {
        params_start: 0,
        params_count: 0,
        return_type: ret_te.1,
        body: r_body.1,
        span: s(),
    }))
    let closure_eid: ExprId = ExprId { id: closure_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, closure_eid)
    tc = re.0
    if not expect_ok(tc, "closure || -> i32") { return 85 }
    if not expect_kind(re.1, "Function", "zero-param closure is Function") { return 85 }

    return 0
}

fn test_match_result_err_binding() -> i32 {
    // match res { Ok(_) => { 0 }, Err(e) => { e } }
    // res: Result#[i32, string] → Err arm binds e as string
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    let res_r: (TypeChecker, KlarType) = make_result_type(tc, type_i32(), type_string())
    tc = res_r.0
    let res_type: KlarType = res_r.1

    tc.push_scope()
    tc.define("res", SymbolInfo {
        sym_name: "res", sym_type: res_type, mutable: false, kind: SymbolKind::Variable,
    })

    let r_subj: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_subj.0

    // Arm 1: Ok(_) => 0
    let ok_wild_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::Wildcard(WildcardData { span: s() }))
    let ok_fields_start: i32 = tc.extra_pattern_ids.len()
    tc.extra_pattern_ids.push(PatternId { id: ok_wild_pid })

    let ok_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::VariantPat(VariantPatData {
        type_expr: no_type_expr(),
        variant_name: "Ok",
        fields_start: ok_fields_start,
        fields_count: 1,
        span: s(),
    }))
    let r_zero: (TypeChecker, ExprId) = add_str_expr(tc, "fallback")
    tc = r_zero.0

    // Arm 2: Err(e) => e (should be string)
    let err_inner_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::BindingPat(BindingPatData {
        binding_name: "e", is_mut: false, span: s(),
    }))
    let err_fields_start: i32 = tc.extra_pattern_ids.len()
    tc.extra_pattern_ids.push(PatternId { id: err_inner_pid })

    let err_pid: i32 = tc.patterns.len()
    tc.patterns.push(Pattern::VariantPat(VariantPatData {
        type_expr: no_type_expr(),
        variant_name: "Err",
        fields_start: err_fields_start,
        fields_count: 1,
        span: s(),
    }))
    let r_e: (TypeChecker, ExprId) = add_ident_expr(tc, "e")
    tc = r_e.0

    let arms_start: i32 = tc.extra_match_arms.len()
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: ok_pid },
        guard: no_expr(),
        body: r_zero.1,
        span: s(),
    })
    tc.extra_match_arms.push(MatchArm {
        pattern: PatternId { id: err_pid },
        guard: no_expr(),
        body: r_e.1,
        span: s(),
    })

    let match_idx: i32 = tc.exprs.len()
    tc.exprs.push(Expr::MatchExpr(MatchExprData {
        subject: r_subj.1,
        arms_start: arms_start,
        arms_count: 2,
        span: s(),
    }))
    let match_eid: ExprId = ExprId { id: match_idx }

    let re: (TypeChecker, KlarType) = check_expr(tc, match_eid)
    tc = re.0
    if not expect_ok(tc, "match Result Err(e) binding") { return 86 }
    // First arm returns "fallback" (string), second returns e (string)
    if not expect_type(re.1, type_string(), "Err(e) binding → string") { return 86 }

    tc.pop_scope()
    return 0
}

