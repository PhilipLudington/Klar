    if not expect_ok(tc, "Some constructor") { return 30 }
    return 0
}

fn test_ok_err_constructor() -> i32 {
    var tc: TypeChecker = TypeChecker.new()

    // Ok(42) → Result#[i32, ?]
    let r_ok_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "Ok")
    tc = r_ok_callee.0
    let r_val: (TypeChecker, ExprId) = add_int_expr(tc, "42")
    tc = r_val.0
    let ok_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_val.1)
    let r_ok_call: (TypeChecker, ExprId) = add_call_expr(tc, r_ok_callee.1, ok_args, 1)
    tc = r_ok_call.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_ok_call.1)
    tc = re1.0
    if not expect_kind(re1.1, "Result", "Ok(42) → Result") { return 31 }
    let ok_inner: KlarType = unwrap_result_ok(tc, re1.1)
    if not expect_type(ok_inner, type_i32(), "Ok(42) ok type is i32") { return 31 }

    // Err("msg") → Result#[?, string]
    let r_err_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "Err")
    tc = r_err_callee.0
    let r_msg: (TypeChecker, ExprId) = add_str_expr(tc, "error")
    tc = r_msg.0
    let err_args: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_msg.1)
    let r_err_call: (TypeChecker, ExprId) = add_call_expr(tc, r_err_callee.1, err_args, 1)
    tc = r_err_call.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_err_call.1)
    tc = re2.0
    if not expect_kind(re2.1, "Result", "Err(\"msg\") → Result") { return 31 }
    let err_inner: KlarType = unwrap_result_err(tc, re2.1)
    if not expect_type(err_inner, type_string(), "Err(\"msg\") err type is string") { return 31 }

    if not expect_ok(tc, "Ok/Err constructors") { return 31 }
    return 0
}

