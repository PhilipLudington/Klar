    tc = r_iok.0
    let re1: (TypeChecker, KlarType) = check_expr(tc, r_iok.1)
    tc = re1.0
    if not expect_type(re1.1, type_bool(), "Result.is_ok() → bool") { return 36 }

    // res.unwrap() → i32
    let r_r2: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_r2.0
    let r_uw: (TypeChecker, ExprId) = add_method_call_expr(tc, r_r2.1, "unwrap", 0, 0)
    tc = r_uw.0
    let re2: (TypeChecker, KlarType) = check_expr(tc, r_uw.1)
    tc = re2.0
    if not expect_type(re2.1, type_i32(), "Result.unwrap() → i32") { return 36 }

    // res.unwrap_err() → string
    let r_r3: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_r3.0
    let r_ue: (TypeChecker, ExprId) = add_method_call_expr(tc, r_r3.1, "unwrap_err", 0, 0)
    tc = r_ue.0
    let re3: (TypeChecker, KlarType) = check_expr(tc, r_ue.1)
    tc = re3.0
    if not expect_type(re3.1, type_string(), "Result.unwrap_err() → string") { return 36 }

    // res.ok() → ?i32
    let r_r4: (TypeChecker, ExprId) = add_ident_expr(tc, "res")
    tc = r_r4.0
    let r_ok: (TypeChecker, ExprId) = add_method_call_expr(tc, r_r4.1, "ok", 0, 0)
    tc = r_ok.0
    let re4: (TypeChecker, KlarType) = check_expr(tc, r_ok.1)
    tc = re4.0
    if not expect_kind(re4.1, "Optional", "Result.ok() → Optional") { return 36 }

    if not expect_ok(tc, "result methods") { return 36 }
    return 0
}

fn test_parse_int_builtin() -> i32 {
    var tc: TypeChecker = TypeChecker.new()
    tc = register_builtins(tc)

    // parse_int("42") → ?i32
    let r_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "parse_int")
    tc = r_callee.0
    let r_arg: (TypeChecker, ExprId) = add_str_expr(tc, "42")
    tc = r_arg.0
    let args_s: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_arg.1)
    let r_call: (TypeChecker, ExprId) = add_call_expr(tc, r_callee.1, args_s, 1)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_kind(re.1, "Optional", "parse_int() → Optional") { return 37 }

    // Verify inner is i32
    let inner: KlarType = unwrap_optional_inner(tc, re.1)
    if not expect_type(inner, type_i32(), "parse_int inner is i32") { return 37 }

    if not expect_ok(tc, "parse_int builtin") { return 37 }
    return 0
}

fn test_none_constructor() -> i32 {
    var tc: TypeChecker = TypeChecker.new()

    // None → ?unknown (no-arg call treated as None constructor)
    let r_callee: (TypeChecker, ExprId) = add_ident_expr(tc, "None")
    tc = r_callee.0
    let r_call: (TypeChecker, ExprId) = add_call_expr(tc, r_callee.1, 0, 0)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_kind(re.1, "Optional", "None → Optional") { return 38 }

    if not expect_ok(tc, "None constructor") { return 38 }
    return 0
}

fn test_generic_apply_result() -> i32 {
    // Build TypeExpr for Result#[i32, string] and resolve it
    var tc: TypeChecker = TypeChecker.new()

    let r_base: (TypeChecker, TypeExprId) = add_type_named(tc, "Result")
    tc = r_base.0
    let r_ok: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = r_ok.0
    let r_err: (TypeChecker, TypeExprId) = add_type_named(tc, "string")
    tc = r_err.0

    let te_args_start: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(r_ok.1)
    tc.extra_type_expr_ids.push(r_err.1)

    let r_ga: (TypeChecker, TypeExprId) = add_type_generic_apply(tc, r_base.1, te_args_start, 2)
    tc = r_ga.0

    let res: (TypeChecker, KlarType) = resolve_type_expr(tc, r_ga.1)
    tc = res.0
    if not expect_kind(res.1, "Result", "Result#[i32, string] resolves to Result") { return 39 }

    // Verify inner types
    let ok_t: KlarType = unwrap_result_ok(tc, res.1)
    if not expect_type(ok_t, type_i32(), "Result ok type is i32") { return 39 }
    let err_t: KlarType = unwrap_result_err(tc, res.1)
    if not expect_type(err_t, type_string(), "Result err type is string") { return 39 }

    if not expect_ok(tc, "GenericApply Result#[i32, string]") { return 39 }
    return 0
}

fn test_method_call_arg_checking() -> i32 {
    // "hello".contains(undefined_var) → should catch undefined variable in arg
    var tc: TypeChecker = TypeChecker.new()

    let r_s: (TypeChecker, ExprId) = add_str_expr(tc, "hello")
    tc = r_s.0
    let r_bad: (TypeChecker, ExprId) = add_ident_expr(tc, "undefined_var")
    tc = r_bad.0
    let args_s: i32 = tc.extra_expr_ids.len()
    tc.extra_expr_ids.push(r_bad.1)
    let r_call: (TypeChecker, ExprId) = add_method_call_expr(tc, r_s.1, "contains", args_s, 1)
    tc = r_call.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_call.1)
    tc = re.0
    if not expect_errors(tc, 1, "method arg with undefined var → error") { return 41 }

    return 0
}

fn test_generic_apply_option() -> i32 {
    // Build TypeExpr for Option#[i32] and resolve it
    var tc: TypeChecker = TypeChecker.new()

    let r_base: (TypeChecker, TypeExprId) = add_type_named(tc, "Option")
    tc = r_base.0
    let r_arg: (TypeChecker, TypeExprId) = add_type_named(tc, "i32")
    tc = r_arg.0

    let te_args_start: i32 = tc.extra_type_expr_ids.len()
    tc.extra_type_expr_ids.push(r_arg.1)

    let r_ga: (TypeChecker, TypeExprId) = add_type_generic_apply(tc, r_base.1, te_args_start, 1)
    tc = r_ga.0

    let res: (TypeChecker, KlarType) = resolve_type_expr(tc, r_ga.1)
    tc = res.0
    if not expect_kind(res.1, "Optional", "Option#[i32] resolves to Optional") { return 42 }

    // Verify inner type is i32
    let inner: KlarType = unwrap_optional_inner(tc, res.1)
    if not expect_type(inner, type_i32(), "Option#[i32] inner is i32") { return 42 }

    if not expect_ok(tc, "GenericApply Option#[i32]") { return 42 }
    return 0
}

fn test_postfix_try_error_on_non_optional() -> i32 {
    var tc: TypeChecker = TypeChecker.new()
    tc.push_scope()

    // x: i32, x? → error
    tc.define("x", SymbolInfo {
        sym_name: "x", sym_type: type_i32(), mutable: false, kind: SymbolKind::Variable,
    })
    let r_x: (TypeChecker, ExprId) = add_ident_expr(tc, "x")
    tc = r_x.0
    let r_try: (TypeChecker, ExprId) = add_postfix_expr(tc, PostfixOp::Try, r_x.1)
    tc = r_try.0
    let re: (TypeChecker, KlarType) = check_expr(tc, r_try.1)
    tc = re.0
    if not expect_errors(tc, 1, "postfix ? on i32 → error") { return 40 }

    return 0
}

