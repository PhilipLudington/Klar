.DS_Store

# Build artifacts (all build outputs go here)
build/

# Zig build artifacts
.zig-cache/
zig-out/

# AirTower result files
.build-results.json
.test-results.json
.native-test-results.json
.module-test-results.json
.app-test-results.json
.args-test-results.json
.freestanding-test-results.json
.benchmark-results.json
.check-test-results.json
.fmt-test-results.json
.doc-test-results.json
.selfhost-test-results.json
.meta-test-results.json
.perf-comparison-results.json

# Python bytecode cache
__pycache__/

# LLVM IR output (when debugging)
*.ll

# AI scratch/sandbox directory
scratch/

# Local planning files
PLAN.md
BUG.md
RESUME.md

# Generated lock files in test fixtures (contain machine-specific absolute paths)
test/pkg/**/klar.lock

# Compilation benchmark generated files (regenerable via scripts)
benchmarks/compile/synthetic_10k.kl
benchmarks/compile/results.json

# Runtime benchmark results (regenerable via scripts)
benchmarks/runtime/results.json
