// Test await used inside if/else control flow

async fn flag() -> Future#[bool] {
    return true
}

async fn value_a() -> Future#[i32] {
    return 42
}

async fn value_b() -> Future#[i32] {
    return 0
}

async fn choose() -> Future#[i32] {
    let cond: bool = await flag()
    if cond {
        return await value_a()
    } else {
        return await value_b()
    }
}

fn main() -> i32 {
    let _f: Future#[i32] = choose()
    return 0
}
