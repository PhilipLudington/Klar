// Test that process_wait drains both stdout and stderr concurrently using poll().
// Expected exit code: 0
// Skip: windows
// Previously, stderr was closed immediately to prevent deadlock. Now both pipes
// are drained via poll(), capturing stderr and preventing deadlock when the child
// writes >64KB to stderr.

fn main() -> i32 {
    // Write 70KB of 'x' to stderr and "hello" to stdout
    let args: List#[string] = List.new#[string]()
    args.push("-c")
    args.push("python3 -c \"import sys; sys.stderr.write('x' * 70000)\" ; echo hello")
    let r: Result#[ProcessHandle, IoError] = process_spawn("/bin/sh", args)
    if not r.is_ok() {
        return 1
    }
    let h: ProcessHandle = r!
    let w: Result#[ProcessOutput, IoError] = process_wait(h)
    if not w.is_ok() {
        return 2
    }
    let o: ProcessOutput = w!

    // Verify stdout captured correctly
    assert_eq(o.stdout, "hello\n")

    // Verify stderr captured (70000 bytes of 'x')
    if o.stderr.len() != 70000 {
        return 3
    }

    assert_eq(o.exit_code, 0)

    return 0
}
