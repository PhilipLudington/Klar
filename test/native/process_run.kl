// Test process_run builtin
// Expected exit code: 42
fn main() -> i32 {
    // Run a simple command: echo "hello"
    var args: List#[string] = List.new#[string]()
    args.push("hello")

    let result: Result#[ProcessOutput, IoError] = process_run("echo", args)
    if not result.is_ok() {
        return 1  // process_run failed
    }

    let output: ProcessOutput = result!
    if output.exit_code != 0 {
        return 2  // echo should exit with 0
    }

    // Verify stdout content was captured correctly
    if output.stdout != "hello\n" {
        return 3  // stdout should be "hello\n"
    }

    // Run a command that fails (exit 1 is cross-platform: works in sh and cmd.exe)
    var args2: List#[string] = List.new#[string]()
    let result2: Result#[ProcessOutput, IoError] = process_run("exit 1", args2)
    if not result2.is_ok() {
        return 4  // process_run should succeed even for failing commands
    }

    let output2: ProcessOutput = result2!
    if output2.exit_code == 0 {
        return 5  // 'exit 1' should exit with non-zero
    }

    // Test output > 4096 bytes to exercise the buffer grow/realloc path.
    // Use platform-appropriate command: awk on POSIX, python on Windows.
    let os_env: ?string = env_get("OS")
    var args3: List#[string] = List.new#[string]()
    var result3: Result#[ProcessOutput, IoError]
    if os_env.is_some() and (os_env ?? "") == "Windows_NT" {
        result3 = process_run("python -c \"for i in range(1,2001): print(i)\"", args3)
    } else {
        result3 = process_run("awk 'BEGIN{for(i=1;i<=2000;i++)print i}'", args3)
    }
    if not result3.is_ok() {
        return 6  // process_run failed for large output
    }

    let output3: ProcessOutput = result3!
    if output3.exit_code != 0 {
        return 7  // command should exit with 0
    }

    // Verify the output is non-trivially large (should be > 4096 bytes)
    let out_len: i32 = output3.stdout.len()
    if out_len < 4096 {
        return 8  // Expected output > 4096 bytes to test realloc path
    }

    // Verify the output starts and ends correctly
    if not output3.stdout.starts_with("1\n2\n") {
        return 9  // Should start with "1\n2\n"
    }
    if not output3.stdout.ends_with("2000\n") {
        return 10  // Should end with "2000\n"
    }

    return 42
}
