// Test List[String].drop() properly frees string element buffers

fn main() -> i32 {
    // Create a list of strings
    var list: List[String] = List.new[String]()

    // Push string literals (each allocates its own heap buffer)
    list.push("hello")
    list.push("world")
    list.push("test string")

    let len: i32 = list.len()
    if len != 3 {
        return 1
    }

    // Drop the list - should free each string's buffer AND the list buffer
    list.drop()

    // Verify list is empty after drop
    let len_after: i32 = list.len()
    if len_after != 0 {
        return 2
    }

    let cap_after: i32 = list.capacity()
    if cap_after != 0 {
        return 3
    }

    // Can push again after drop (starts fresh)
    list.push("new string")
    let len2: i32 = list.len()
    if len2 != 1 {
        return 4
    }

    // Drop again
    list.drop()

    let final_len: i32 = list.len()
    if final_len != 0 {
        return 5
    }

    return 42
}
