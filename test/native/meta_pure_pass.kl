// Test: meta pure verification — pure functions compile and run correctly

// Pure function with only arithmetic
meta pure
fn add(a: i32, b: i32) -> i32 {
    return a + b
}

// Pure function calling another pure function (transitive)
meta pure
fn add_three(a: i32, b: i32, c: i32) -> i32 {
    return add(a, add(b, c))
}

// Pure function with local var and loop accumulator
meta pure
fn sum_to(n: i32) -> i32 {
    var total: i32 = 0
    for i: i32 in 0..n {
        total = total + i
    }
    return total
}

// Pure function with let bindings and control flow
meta pure
fn max(a: i32, b: i32) -> i32 {
    if a > b {
        return a
    }
    return b
}

// Pure function with local struct creation
struct Point { x: i32, y: i32 }

meta pure
fn make_point(x: i32, y: i32) -> Point {
    return Point { x: x, y: y }
}

// Pure function with closure (closure inherits purity context)
meta pure
fn apply_twice(x: i32) -> i32 {
    let double: fn(i32) -> i32 = |n: i32| -> i32 { return n * 2 }
    return double(double(x))
}

// Pure method on a struct
impl Point {
    meta pure
    fn manhattan(self: Point) -> i32 {
        return self.x + self.y
    }
}

// Pure function calling a pure method
meta pure
fn point_distance(p: Point) -> i32 {
    return p.manhattan()
}

fn main() -> i32 {
    let r1: i32 = add(3, 4)
    let r2: i32 = add_three(1, 2, 3)
    let r3: i32 = sum_to(5)
    let r4: i32 = max(10, 20)
    let p: Point = make_point(1, 2)
    let r6: i32 = apply_twice(3)
    let r7: i32 = point_distance(p)
    if r1 == 7 and r2 == 6 and r3 == 10 and r4 == 20 and p.x == 1 and r6 == 12 and r7 == 3 {
        println("ok")
    }
    return 0
}
