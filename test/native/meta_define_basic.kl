// Test: basic custom annotation definition and usage
meta define priority(level: "high" | "medium" | "low")

meta priority("high")
fn important_work() -> i32 {
    return 42
}

meta priority("low")
fn background_task() -> i32 {
    return 1
}

fn main() -> i32 {
    let result: i32 = important_work() + background_task()
    // 42 + 1 = 43, but we want exit 0
    if result == 43 {
        return 0
    }
    return 1
}
