// Test async subprocess builtins on Windows: process_spawn, process_wait, process_read_stdout
// Expected exit code: 0
// Requires: windows

fn main() -> i32 {
    // Test 1: spawn cmd.exe /C echo, wait for completion, check output
    let args1: List#[string] = List.new#[string]()
    args1.push("/C")
    args1.push("echo hello world")
    let r1: Result#[ProcessHandle, IoError] = process_spawn("cmd.exe", args1)
    if not r1.is_ok() {
        return 1
    }
    let h1: ProcessHandle = r1!
    let w1: Result#[ProcessOutput, IoError] = process_wait(h1)
    if not w1.is_ok() {
        return 2
    }
    let o1: ProcessOutput = w1!
    assert_eq(o1.exit_code, 0)

    // Test 2: process that exits with non-zero code
    let args2: List#[string] = List.new#[string]()
    args2.push("/C")
    args2.push("exit /B 42")
    let r2: Result#[ProcessHandle, IoError] = process_spawn("cmd.exe", args2)
    if not r2.is_ok() {
        return 3
    }
    let h2: ProcessHandle = r2!
    let w2: Result#[ProcessOutput, IoError] = process_wait(h2)
    if not w2.is_ok() {
        return 4
    }
    let o2: ProcessOutput = w2!
    assert_eq(o2.exit_code, 42)

    // Test 3: process_read_stdout (incremental read)
    let args3: List#[string] = List.new#[string]()
    args3.push("/C")
    args3.push("echo test output")
    let r3: Result#[ProcessHandle, IoError] = process_spawn("cmd.exe", args3)
    if not r3.is_ok() {
        return 5
    }
    let h3: ProcessHandle = r3!
    let rd: Result#[string, IoError] = process_read_stdout(h3, 4096)
    if not rd.is_ok() {
        return 6
    }
    // Clean up: wait to reap child
    let _w3: Result#[ProcessOutput, IoError] = process_wait(h3)

    // Test 4: process_poll on running then completed process
    let args4: List#[string] = List.new#[string]()
    args4.push("/C")
    args4.push("echo done")
    let r4: Result#[ProcessHandle, IoError] = process_spawn("cmd.exe", args4)
    if not r4.is_ok() {
        return 7
    }
    let h4: ProcessHandle = r4!
    // Wait for it to finish, then poll should show Exited
    let w4: Result#[ProcessOutput, IoError] = process_wait(h4)
    if not w4.is_ok() {
        return 8
    }

    return 0
}
