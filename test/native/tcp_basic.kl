// Test TCP socket builtins: tcp_listen, tcp_accept, tcp_connect, tcp_read, tcp_write, tcp_close
// Uses process_spawn to create a client subprocess that connects to the server.
// Expected exit code: 0
// Skip: windows

fn main() -> i32 {
    // Start a TCP server on a high port
    let lr: Result#[TcpListener, IoError] = tcp_listen("127.0.0.1", 19876)
    if not lr.is_ok() {
        println("tcp_listen failed")
        return 1
    }
    let listener: TcpListener = lr!

    // Spawn a subprocess that connects and sends data using printf (not echo -n)
    let args: List#[string] = List.new#[string]()
    args.push("-c")
    args.push("sleep 0.1 && printf 'hello tcp' | nc 127.0.0.1 19876")
    let sr: Result#[ProcessHandle, IoError] = process_spawn("/bin/sh", args)
    if not sr.is_ok() {
        tcp_listener_close(listener)
        println("process_spawn failed")
        return 2
    }
    let child: ProcessHandle = sr!

    // Accept a connection
    let ar: Result#[TcpStream, IoError] = tcp_accept(listener)
    if not ar.is_ok() {
        tcp_listener_close(listener)
        println("tcp_accept failed")
        return 3
    }
    let stream: TcpStream = ar!

    // Read data from the client
    let rr: Result#[string, IoError] = tcp_read(stream, 4096)
    if not rr.is_ok() {
        tcp_close(stream)
        tcp_listener_close(listener)
        println("tcp_read failed")
        return 4
    }
    let data: string = rr!
    assert_eq(data, "hello tcp")

    // Send a response
    let wr: Result#[i32, IoError] = tcp_write(stream, "ok")
    if not wr.is_ok() {
        tcp_close(stream)
        tcp_listener_close(listener)
        println("tcp_write failed")
        return 5
    }

    // Clean up
    tcp_close(stream)
    tcp_listener_close(listener)

    // Wait for child
    let _w: Result#[ProcessOutput, IoError] = process_wait(child)

    return 0
}
