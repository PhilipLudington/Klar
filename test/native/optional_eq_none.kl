// Test: optional == None and != None comparisons in if conditions
// Bug 4: `if v == None` was a parse error because `None {` was misinterpreted as struct literal

fn main() -> i32 {
    // Test 1: None == None
    let v1: ?i32 = None
    if v1 == None {
        // OK
    } else {
        return 1
    }

    // Test 2: Some != None
    let v2: ?i32 = Some(42)
    if v2 != None {
        // OK
    } else {
        return 2
    }

    // Test 3: Some == None should be false
    if v2 == None {
        return 3
    }

    // Test 4: None != None should be false
    if v1 != None {
        return 4
    }

    // Test 5: reversed — None == optional
    if None == v1 {
        // OK
    } else {
        return 5
    }

    // Test 6: reversed — None != Some
    if None != v2 {
        // OK
    } else {
        return 6
    }

    // Test 7: optional string with None
    let v3: ?string = None
    if v3 == None {
        // OK
    } else {
        return 7
    }

    // Test 8: optional string with Some
    let v4: ?string = Some("hello")
    if v4 != None {
        // OK
    } else {
        return 8
    }
    if v4 == None {
        return 9
    }

    // Test 9: reversed None == ?string (v3 is None)
    if None == v3 {
        // OK
    } else {
        return 10
    }

    // Test 10: reversed None != ?string (v4 is Some)
    if None != v4 {
        // OK — None != Some("hello") is true
    } else {
        return 11
    }

    // Test 10: struct literal inside function call in if condition
    // (regression: no_struct_literal must be reset inside parens)
    var m: Map#[string, i32] = Map.new#[string, i32]()
    m.insert("x", 1)
    if m.len() == 1 {
        // OK
    } else {
        return 12
    }

    return 0
}
