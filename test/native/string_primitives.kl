fn main() -> i32 {
    let s: string = "hello"

    // byte_at returns u8
    let b0: u8 = s.byte_at(0)
    let b4: u8 = s.byte_at(4)
    assert_eq(b0, 104.as#[u8])
    assert_eq(b4, 111.as#[u8])

    // byte_len
    assert_eq(s.byte_len(), 5)
    assert_eq("".byte_len(), 0)

    // len() is now char count (same as byte_len for ASCII)
    assert_eq(s.len(), 5)

    // substring (char-indexed) - verify via len and contains
    let sub1: string = s.substring(1, 4)
    assert_eq(sub1.len(), 3)
    assert(sub1.contains("ell"))
    let sub2: string = s.substring(0, 5)
    assert_eq(sub2.len(), 5)
    assert(sub2.contains("hello"))

    // substring edge cases
    let empty1: string = s.substring(3, 3)
    assert_eq(empty1.len(), 0)
    let empty2: string = s.substring(5, 3)
    assert_eq(empty2.len(), 0)
    let empty3: string = s.substring(10, 20)
    assert_eq(empty3.len(), 0)

    // index_of
    let idx: ?i32 = s.index_of("ell")
    assert_some(idx)
    let none_idx: ?i32 = s.index_of("xyz")
    assert_none(none_idx)

    // from_byte
    let ch: string = from_byte(65.as#[u8])
    assert_eq(ch.len(), 1)
    assert_eq(ch.byte_at(0), 65.as#[u8])

    // parse_int
    let n: ?i64 = parse_int("42")
    assert_some(n)
    let bad_n: ?i64 = parse_int("abc")
    assert_none(bad_n)
    let empty_n: ?i64 = parse_int("")
    assert_none(empty_n)

    // parse_float
    let f: ?f64 = parse_float("3.14")
    assert_some(f)
    let bad_f: ?f64 = parse_float("xyz")
    assert_none(bad_f)
    let empty_f: ?f64 = parse_float("")
    assert_none(empty_f)

    // ================================================================
    // UTF-8 multi-byte tests
    // ================================================================

    // 2-byte UTF-8: "cafe\xcc\x81" = "caf\xc3\xa9" = cafe with accent
    // Use a string with known multi-byte chars
    // "hi" is 2 bytes, 2 codepoints (baseline ASCII check)
    let ascii: string = "hi"
    assert_eq(ascii.len(), 2)
    assert_eq(ascii.byte_len(), 2)

    // len() vs byte_len() free function consistency
    assert_eq(len(s), s.len())
    assert_eq(len(ascii), ascii.len())

    println("All string primitive tests passed!")
    return 0
}
