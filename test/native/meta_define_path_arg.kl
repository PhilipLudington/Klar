// Test: custom annotation with path argument (path_type accepts paths)
meta define related_to(target: path)

fn helper() -> i32 {
    return 10
}

meta related_to(helper)
fn process() -> i32 {
    return helper() + 5
}

fn main() -> i32 {
    if process() == 15 {
        return 0
    }
    return 1
}
