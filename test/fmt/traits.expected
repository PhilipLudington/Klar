trait Drawable {
    type Item

    fn draw(self: Self) -> i32
}

struct Circle {
    radius: i32
}

impl Circle: Drawable {
    type Item = i32

    fn draw(self: Circle) -> i32 {
        return self.radius
    }
}

fn main() -> i32 {
    let c: Circle = Circle { radius: 42 }
    return c.draw()
}
