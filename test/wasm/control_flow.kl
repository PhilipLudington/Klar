// Test control flow in WebAssembly
// Expected: build-success

fn abs(x: i32) -> i32 {
    if x < 0 {
        return -x
    }
    return x
}

fn fib(n: i32) -> i32 {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

fn main() -> i32 {
    let a: i32 = abs(-42)
    let b: i32 = fib(10)
    return a + b
}
