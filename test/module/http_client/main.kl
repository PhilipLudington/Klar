// Test HTTP client library
// Uses curl + http_server stdlib instead of nc for cross-platform compatibility.
// Expected exit code: 0

import stdlib.http_server.*
import stdlib.http_client.*

fn main() -> i32 {
    // Test 1: HTTP GET — curl as client, http_server as server
    let curl_args1: List#[string] = List.new#[string]()
    curl_args1.push("-c")
    curl_args1.push("sleep 0.3 && curl -s http://127.0.0.1:19883/test")
    let curl1: Result#[ProcessHandle, IoError] = process_spawn("/bin/sh", curl_args1)
    if not curl1.is_ok() {
        println("Failed to spawn curl for test 1")
        return 1
    }

    let ar1: Result#[HttpConnection, string] = http_server_accept("127.0.0.1", 19883)
    if not ar1.is_ok() {
        println("Failed to accept for test 1")
        return 2
    }
    let conn1: HttpConnection = ar1!
    assert_eq(conn1.request.method, "GET")
    http_server_respond_and_close(conn1, http_ok("hello"))

    let wr1: Result#[ProcessOutput, IoError] = process_wait(curl1!)
    if not wr1.is_ok() {
        println("Failed to wait for curl test 1")
        return 3
    }
    let o1: ProcessOutput = wr1!
    assert_eq(o1.stdout, "hello")

    // Test 2: HTTP POST — curl sends body, http_server verifies method and responds
    let curl_args2: List#[string] = List.new#[string]()
    curl_args2.push("-c")
    curl_args2.push("sleep 0.3 && curl -s -X POST -d 'test body' http://127.0.0.1:19884/api")
    let curl2: Result#[ProcessHandle, IoError] = process_spawn("/bin/sh", curl_args2)
    if not curl2.is_ok() {
        println("Failed to spawn curl for test 2")
        return 4
    }

    let ar2: Result#[HttpConnection, string] = http_server_accept("127.0.0.1", 19884)
    if not ar2.is_ok() {
        println("Failed to accept for test 2")
        return 5
    }
    let conn2: HttpConnection = ar2!
    assert_eq(conn2.request.method, "POST")
    http_server_respond_and_close(conn2, http_error(201, "created"))

    let wr2: Result#[ProcessOutput, IoError] = process_wait(curl2!)
    if not wr2.is_ok() { return 6 }
    let o2: ProcessOutput = wr2!
    assert_eq(o2.stdout, "created")

    // Test 3: Integration — curl fetches JSON response from http_server
    let curl_args3: List#[string] = List.new#[string]()
    curl_args3.push("-c")
    curl_args3.push("sleep 0.3 && curl -s http://127.0.0.1:19885/api/hello")
    let curl3: Result#[ProcessHandle, IoError] = process_spawn("/bin/sh", curl_args3)
    if not curl3.is_ok() { return 7 }

    let ar3: Result#[HttpConnection, string] = http_server_accept("127.0.0.1", 19885)
    if not ar3.is_ok() { return 8 }
    let conn3: HttpConnection = ar3!
    assert_eq(conn3.request.method, "GET")
    http_server_respond_and_close(conn3, http_json_response("ok"))

    let wr3: Result#[ProcessOutput, IoError] = process_wait(curl3!)
    if not wr3.is_ok() { return 9 }
    let o3: ProcessOutput = wr3!
    assert_eq(o3.stdout, "ok")

    return 0
}
