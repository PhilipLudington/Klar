// ============================================================================
// Test: Whitespace Handling
// ============================================================================

fn test_whitespace_around_values() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("  42  ")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "42", 20) }
        Err(_) => { return fail(20, "parse failed") }
    }
}

fn test_whitespace_in_array() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("[ 1 , 2 , 3 ]")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "[1,2,3]", 21) }
        Err(_) => { return fail(21, "parse failed") }
    }
}

fn test_whitespace_in_object() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("  {  \"a\"  :  1  }  ")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "{\"a\":1}", 22) }
        Err(_) => { return fail(22, "parse failed") }
    }
}

// ============================================================================
// Test: Escape Sequences (verified via round-trip stringify)
// ============================================================================

fn test_escape_quote() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("\"a\\\"b\"")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "\"a\\\"b\"", 30) }
        Err(_) => { return fail(30, "parse failed") }
    }
}

fn test_escape_backslash() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("\"a\\\\b\"")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "\"a\\\\b\"", 31) }
        Err(_) => { return fail(31, "parse failed") }
    }
}

fn test_escape_newline() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("\"a\\nb\"")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "\"a\\nb\"", 32) }
        Err(_) => { return fail(32, "parse failed") }
    }
}

fn test_escape_tab() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("\"a\\tb\"")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "\"a\\tb\"", 33) }
        Err(_) => { return fail(33, "parse failed") }
    }
}

fn test_escape_unicode() -> i32 {
    // \u0041 = 'A'
    let r: Result#[JsonValue, JsonError] = json_parse("\"\\u0041\"")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "\"A\"", 34) }
        Err(_) => { return fail(34, "parse failed") }
    }
}

fn test_escape_slash() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("\"a\\/b\"")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "\"a/b\"", 35) }
        Err(_) => { return fail(35, "parse failed") }
    }
}

fn test_escape_surrogate_pair() -> i32 {
    // \uD83D\uDE00 = U+1F600 (grinning face emoji)
    let r: Result#[JsonValue, JsonError] = json_parse("\"\\uD83D\\uDE00\"")
    match r {
        Ok(_) => { return 0 }  // Parsed successfully (emoji bytes)
        Err(_) => { return fail(36, "surrogate pair parse failed") }
    }
}

fn test_escape_lone_surrogate_err() -> i32 {
    // Lone high surrogate should be an error
    return expect_err(json_parse("\"\\uD800\""), 37)
}

fn test_escape_lone_low_surrogate_err() -> i32 {
    // Lone low surrogate should be an error
    return expect_err(json_parse("\"\\uDC00\""), 38)
}

