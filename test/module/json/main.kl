    }
}

fn test_number_neg_exponent() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("1e-1")
    match r {
        Ok(_) => { return 0 }
        Err(_) => { return fail(42, "parse failed") }
    }
}

fn test_number_large() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("1000000")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "1000000", 43) }
