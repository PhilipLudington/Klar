// test/module/json/main.kl - Comprehensive tests for stdlib/json.kl
// Tests: parsing, stringification, round-trip, accessors, error handling
// Returns 0 on success, non-zero test number on failure
//
// Note: Tests use json_stringify for value comparison and json_get_* accessors
// for field extraction, avoiding direct enum payload extraction across modules
// (which has a known codegen issue with string length fields).

import stdlib.json.*

// ============================================================================
// Test Helpers
// ============================================================================

fn fail(test_num: i32, msg: string) -> i32 {
    print("FAIL test ")
    print(test_num.to_string().as_str())
    print(": ")
    println(msg)
    return test_num
}

fn expect_str(actual: string, expected: string, test_num: i32) -> i32 {
    if actual != expected {
        print("FAIL test ")
        print(test_num.to_string().as_str())
        print(": expected '")
        print(expected)
        print("' got '")
        print(actual)
        println("'")
        return test_num
    }
    return 0
}

fn expect_ok(r: Result#[JsonValue, JsonError], test_num: i32) -> i32 {
    match r {
        Ok(_) => { return 0 }
        Err(_) => { return fail(test_num, "expected Ok, got Err") }
    }
}

fn expect_err(r: Result#[JsonValue, JsonError], test_num: i32) -> i32 {
    match r {
        Ok(_) => { return fail(test_num, "expected Err, got Ok") }
        Err(_) => { return 0 }
    }
}

// ============================================================================
// Test: Parse Primitives (verified via stringify)
// ============================================================================

fn test_parse_null() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("null")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "null", 1) }
        Err(_) => { return fail(1, "parse failed") }
    }
}

fn test_parse_true() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("true")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "true", 2) }
        Err(_) => { return fail(2, "parse failed") }
    }
}

fn test_parse_false() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("false")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "false", 3) }
        Err(_) => { return fail(3, "parse failed") }
    }
}

fn test_parse_integer() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("42")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "42", 4) }
        Err(_) => { return fail(4, "parse failed") }
    }
}

fn test_parse_negative() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("-7")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "-7", 5) }
        Err(_) => { return fail(5, "parse failed") }
    }
}

fn test_parse_zero() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("0")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "0", 6) }
        Err(_) => { return fail(6, "parse failed") }
    }
}

fn test_parse_string() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("\"hello\"")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "\"hello\"", 7) }
        Err(_) => { return fail(7, "parse failed") }
    }
}

fn test_parse_empty_string() -> i32 {
    let r: Result#[JsonValue, JsonError] = json_parse("\"\"")
    match r {
        Ok(v) => { return expect_str(json_stringify(v), "\"\"", 8) }
        Err(_) => { return fail(8, "parse failed") }
    }
}

