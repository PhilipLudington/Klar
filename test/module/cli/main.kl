// ============================================================================
// Test 29: Complex mixed args
// ============================================================================

fn test_complex_mixed() -> i32 {
    let p: ArgParser = lodex_parser()
    var args: List#[string] = List.new#[string]()
    args.push("-v")
    args.push("checkpoint")
    args.push("-g")
    args.push("optimize auth")
    args.push("--strategy=cache")
    args.push("-j")
    let r: Result#[ParsedArgs, ArgError] = cli_parse(p, args)
    match r {
        Ok(parsed) => {
            if parsed.subcommand != "checkpoint" { return fail(29, "expected 'checkpoint'") }
            if not cli_get_flag(parsed, "verbose") { return fail(29, "verbose should be true") }
            if not cli_get_flag(parsed, "json") { return fail(29, "json should be true") }
            let g: ?string = cli_get_option(parsed, "goal")
            match g {
                Some(v) => { if v != "optimize auth" { return fail(29, "wrong goal") } }
                None => { return fail(29, "goal not found") }
            }
            let s: ?string = cli_get_option(parsed, "strategy")
            match s {
                Some(v) => { if v != "cache" { return fail(29, "wrong strategy") } }
                None => { return fail(29, "strategy not found") }
            }
            return 0
        }
        Err(e) => { return fail(29, e.message) }
    }
}

// ============================================================================
// Test 30: cli_has_subcommand
// ============================================================================

fn test_has_subcommand() -> i32 {
    let p: ArgParser = lodex_parser()
    var args: List#[string] = List.new#[string]()
    args.push("init")
    let r: Result#[ParsedArgs, ArgError] = cli_parse(p, args)
    match r {
        Ok(parsed) => {
            if not cli_has_subcommand(parsed) { return fail(30, "should have subcommand") }
            return 0
        }
        Err(e) => { return fail(30, e.message) }
    }
}

