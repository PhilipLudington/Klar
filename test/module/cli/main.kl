            let pos: List#[string] = parsed.positional
            if pos.len() != 2 { return fail(15, "expected 2 positional") }
            let p1: string = pos.get(0)!
            if p1 != "file1.txt" { return fail(15, "wrong first positional") }
            return 0
        }
        Err(e) => { return fail(15, e.message) }
    }
}

