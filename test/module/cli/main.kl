// ============================================================================
// Test 14: -- separator
// ============================================================================

fn test_separator() -> i32 {
    let p: ArgParser = lodex_parser()
    var args: List#[string] = List.new#[string]()
    args.push("--json")
    args.push("--")
    args.push("--not-a-flag")
    args.push("positional")
    let r: Result#[ParsedArgs, ArgError] = cli_parse(p, args)
    match r {
        Ok(parsed) => {
            if not cli_get_flag(parsed, "json") { return fail(14, "json should be true") }
            let pos: List#[string] = parsed.positional
            if pos.len() != 2 { return fail(14, "expected 2 positional") }
            let p1: string = pos.get(0)!
            if p1 != "--not-a-flag" { return fail(14, "wrong first positional") }
            let p2: string = pos.get(1)!
            if p2 != "positional" { return fail(14, "wrong second positional") }
            return 0
        }
        Err(e) => { return fail(14, e.message) }
    }
}

