fn test_subcommand_only() -> i32 {
    let p: ArgParser = lodex_parser()
    var args: List#[string] = List.new#[string]()
    args.push("init")
    let r: Result#[ParsedArgs, ArgError] = cli_parse(p, args)
    match r {
        Ok(parsed) => {
            if parsed.subcommand != "init" { return fail(2, "expected 'init'") }
            return 0
        }
        Err(e) => { return fail(2, e.message) }
    }
}

