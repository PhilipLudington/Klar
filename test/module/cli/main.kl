// ============================================================================
// Test 5: Long option with separate value
// ============================================================================

fn test_long_option() -> i32 {
    let p: ArgParser = lodex_parser()
    var args: List#[string] = List.new#[string]()
    args.push("--goal")
    args.push("optimize auth")
    let r: Result#[ParsedArgs, ArgError] = cli_parse(p, args)
    match r {
        Ok(parsed) => {
            let val: ?string = cli_get_option(parsed, "goal")
            match val {
                Some(v) => {
                    if v != "optimize auth" { return fail(5, "expected 'optimize auth'") }
                    return 0
                }
                None => { return fail(5, "goal not found") }
            }
        }
        Err(e) => { return fail(5, e.message) }
    }
}

