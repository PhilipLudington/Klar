// test/module/cli/main.kl - Comprehensive tests for stdlib/cli.kl
// Tests: flags, options, subcommands, short flags, --key=value, -- separator,
//        unknown flags, missing values, help generation, positional args
// Models the Lodex CLI: init, checkpoint, tree, export
// Returns 0 on success, non-zero test number on failure

import stdlib.cli.*

// ============================================================================
// Test Helpers
// ============================================================================

fn fail(test_num: i32, msg: string) -> i32 {
    print("FAIL test ")
    print(test_num.to_string().as_str())
    print(": ")
    println(msg)
    return test_num
}

fn lodex_parser() -> ArgParser {
    var fn2: List#[string] = List.new#[string]()
    var fs2: List#[string] = List.new#[string]()
    var fd2: List#[string] = List.new#[string]()
    cli_def_flag(fn2, fs2, fd2, "json", "j", "Output as JSON")
    cli_def_flag(fn2, fs2, fd2, "verbose", "v", "Verbose output")

    var on2: List#[string] = List.new#[string]()
    var os2: List#[string] = List.new#[string]()
    var od2: List#[string] = List.new#[string]()
    var odef2: List#[string] = List.new#[string]()
    cli_def_option(on2, os2, od2, odef2, "goal", "g", "Set the goal", "")
    cli_def_option(on2, os2, od2, odef2, "strategy", "s", "Set the strategy", "")
    cli_def_option(on2, os2, od2, odef2, "squash-strategy", "", "Squash strategy", "")

    var sn2: List#[string] = List.new#[string]()
    var sd2: List#[string] = List.new#[string]()
    cli_def_subcommand(sn2, sd2, "init", "Initialize a new repository")
    cli_def_subcommand(sn2, sd2, "checkpoint", "Create a checkpoint")
    cli_def_subcommand(sn2, sd2, "tree", "Show checkpoint tree")
    cli_def_subcommand(sn2, sd2, "export", "Export changes")

    return ArgParser {
        name: "lodex", description: "AI-native source control",
        flag_names: fn2, flag_shorts: fs2, flag_descs: fd2,
        opt_names: on2, opt_shorts: os2, opt_descs: od2, opt_defaults: odef2,
        sub_names: sn2, sub_descs: sd2,
    }
}

fn simple_parser() -> ArgParser {
    var fn2: List#[string] = List.new#[string]()
    var fs2: List#[string] = List.new#[string]()
    var fd2: List#[string] = List.new#[string]()
    cli_def_flag(fn2, fs2, fd2, "verbose", "v", "Verbose")

    var on2: List#[string] = List.new#[string]()
    var os2: List#[string] = List.new#[string]()
    var od2: List#[string] = List.new#[string]()
    var odef2: List#[string] = List.new#[string]()

    var sn2: List#[string] = List.new#[string]()
    var sd2: List#[string] = List.new#[string]()

    return ArgParser {
        name: "tool", description: "A tool",
        flag_names: fn2, flag_shorts: fs2, flag_descs: fd2,
        opt_names: on2, opt_shorts: os2, opt_descs: od2, opt_defaults: odef2,
        sub_names: sn2, sub_descs: sd2,
    }
}

fn default_parser() -> ArgParser {
    var fn2: List#[string] = List.new#[string]()
    var fs2: List#[string] = List.new#[string]()
    var fd2: List#[string] = List.new#[string]()

    var on2: List#[string] = List.new#[string]()
    var os2: List#[string] = List.new#[string]()
    var od2: List#[string] = List.new#[string]()
    var odef2: List#[string] = List.new#[string]()
    cli_def_option(on2, os2, od2, odef2, "format", "f", "Output format", "text")

    var sn2: List#[string] = List.new#[string]()
    var sd2: List#[string] = List.new#[string]()

    return ArgParser {
        name: "tool", description: "A tool",
        flag_names: fn2, flag_shorts: fs2, flag_descs: fd2,
        opt_names: on2, opt_shorts: os2, opt_descs: od2, opt_defaults: odef2,
        sub_names: sn2, sub_descs: sd2,
    }
}

fn str_contains(haystack: string, needle: string) -> bool {
    let h: [char] = haystack.chars()
    let n: [char] = needle.chars()
    let hlen: i32 = h.len()
    let nlen: i32 = n.len()
    if nlen > hlen { return false }
    var i: i32 = 0
    while i <= hlen - nlen {
        var found: bool = true
        var j: i32 = 0
        while j < nlen {
            if h[i + j] != n[j] {
                found = false
                j = nlen
            } else {
                j = j + 1
            }
        }
        if found { return true }
        i = i + 1
    }
    return false
}

// ============================================================================
// Test 1: Empty args
// ============================================================================

fn test_empty_args() -> i32 {
    let p: ArgParser = lodex_parser()
    let r: Result#[ParsedArgs, ArgError] = cli_parse(p, List.new#[string]())
    match r {
        Ok(parsed) => {
            if cli_get_flag(parsed, "json") { return fail(1, "json should be false") }
            let pos: List#[string] = parsed.positional
            if pos.len() != 0 { return fail(1, "expected 0 positional") }
            return 0
        }
        Err(e) => { return fail(1, e.message) }
    }
}

