// ============================================================================
// Test 21: Non-subcommand word becomes positional
// ============================================================================

fn test_non_subcmd_positional() -> i32 {
    let p: ArgParser = lodex_parser()
    var args: List#[string] = List.new#[string]()
    args.push("unknown_cmd")
    let r: Result#[ParsedArgs, ArgError] = cli_parse(p, args)
    match r {
        Ok(parsed) => {
            if cli_has_subcommand(parsed) { return fail(21, "expected no subcommand") }
            let pos: List#[string] = parsed.positional
            if pos.len() != 1 { return fail(21, "expected 1 positional") }
            return 0
        }
        Err(e) => { return fail(21, e.message) }
    }
}

// ============================================================================
// Test 22: Help generation content
// ============================================================================

fn test_help_content() -> i32 {
    let p: ArgParser = lodex_parser()
    let help: string = cli_help(p)
    if not str_contains(help, "lodex") { return fail(22, "should contain 'lodex'") }
    if not str_contains(help, "checkpoint") { return fail(22, "should contain 'checkpoint'") }
    if not str_contains(help, "--goal") { return fail(22, "should contain '--goal'") }
    if not str_contains(help, "AI-native source control") { return fail(22, "should contain description") }
    return 0
}

