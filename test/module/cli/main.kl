// ============================================================================
// Test 8: Full Lodex checkpoint command
// ============================================================================

fn test_lodex_checkpoint() -> i32 {
    let p: ArgParser = lodex_parser()
    var args: List#[string] = List.new#[string]()
    args.push("checkpoint")
    args.push("--goal")
    args.push("optimize auth")
    args.push("--strategy")
    args.push("cache")
    args.push("--json")
    let r: Result#[ParsedArgs, ArgError] = cli_parse(p, args)
    match r {
        Ok(parsed) => {
            if parsed.subcommand != "checkpoint" { return fail(8, "expected 'checkpoint'") }
            if not cli_get_flag(parsed, "json") { return fail(8, "json should be true") }
            let g: ?string = cli_get_option(parsed, "goal")
            match g {
                Some(v) => { if v != "optimize auth" { return fail(8, "wrong goal") } }
                None => { return fail(8, "goal not found") }
            }
            let s: ?string = cli_get_option(parsed, "strategy")
            match s {
                Some(v) => { if v != "cache" { return fail(8, "wrong strategy") } }
                None => { return fail(8, "strategy not found") }
            }
            return 0
        }
        Err(e) => { return fail(8, e.message) }
    }
}

