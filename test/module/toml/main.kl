// ============================================================================
// Test: Inline Tables
// ============================================================================

fn test_inline_table() -> i32 {
    let input: string = "point = {x = 1, y = 2}"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let pt: ?TomlValue = toml_get(v, "point")
            match pt {
                Some(pv) => {
                    let x: ?i64 = toml_get_integer(pv, "x")
                    match x {
                        Some(xv) => {
                            if xv != 1.as#[i64] { return fail(50, "expected x=1") }
                            let y: ?i64 = toml_get_integer(pv, "y")
                            match y {
                                Some(yv) => {
                                    if yv == 2.as#[i64] { return 0 }
                                    return fail(50, "expected y=2")
                                }
                                None => { return fail(50, "y not found") }
                            }
                        }
                        None => { return fail(50, "x not found") }
                    }
                }
                None => { return fail(50, "point not found") }
            }
        }
        Err(_) => { return fail(50, "parse failed") }
    }
}

fn test_empty_inline_table() -> i32 {
    let input: string = "empty = {}"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let t: ?Map#[string, TomlValue] = toml_get_table(v, "empty")
            match t {
                Some(m) => {
                    if m.keys().len() == 0 { return 0 }
                    return fail(51, "expected empty table")
                }
                None => { return fail(51, "empty not found") }
            }
        }
        Err(_) => { return fail(51, "parse failed") }
    }
}

// ============================================================================
// Test: Array of Tables
// ============================================================================

fn test_array_of_tables() -> i32 {
    let input: string = "[[products]]\nname = \"Hammer\"\n\n[[products]]\nname = \"Nail\""
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let prods: ?List#[TomlValue] = toml_get_array(v, "products")
            match prods {
                Some(a) => {
                    if a.len() != 2 { return fail(60, "expected 2 products") }
                    let first: TomlValue = a.get(0)!
                    let name1: ?string = toml_get_string(first, "name")
                    match name1 {
                        Some(n) => {
                            if n != "Hammer" { return fail(60, "expected 'Hammer'") }
                        }
                        None => { return fail(60, "name not found in first") }
                    }
                    let second: TomlValue = a.get(1)!
                    let name2: ?string = toml_get_string(second, "name")
                    match name2 {
                        Some(n) => {
                            if n == "Nail" { return 0 }
                            return fail(60, "expected 'Nail'")
                        }
                        None => { return fail(60, "name not found in second") }
                    }
                }
                None => { return fail(60, "products not found") }
            }
        }
        Err(_) => { return fail(60, "parse failed") }
    }
}

