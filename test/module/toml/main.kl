// test/module/toml/main.kl - Comprehensive tests for stdlib/toml.kl
// Tests: parsing primitives, sections, dotted keys, inline tables, arrays,
//        array of tables, accessors, error handling, and lodex.toml-style config
// Returns 0 on success, non-zero test number on failure

import stdlib.toml.*

// ============================================================================
// Test Helpers
// ============================================================================

fn fail(test_num: i32, msg: string) -> i32 {
    print("FAIL test ")
    print(test_num.to_string().as_str())
    print(": ")
    println(msg)
    return test_num
}

fn expect_str(actual: string, expected: string, test_num: i32) -> i32 {
    if actual != expected {
        print("FAIL test ")
        print(test_num.to_string().as_str())
        print(": expected '")
        print(expected)
        print("' got '")
        print(actual)
        println("'")
        return test_num
    }
    return 0
}

fn expect_ok(r: Result#[TomlValue, TomlError], test_num: i32) -> i32 {
    match r {
        Ok(_) => { return 0 }
        Err(e) => {
            print("FAIL test ")
            print(test_num.to_string().as_str())
            print(": expected Ok, got Err: ")
            print(e.message)
            print(" at line ")
            println(e.line.to_string().as_str())
            return test_num
        }
    }
}

fn expect_err(r: Result#[TomlValue, TomlError], test_num: i32) -> i32 {
    match r {
        Ok(_) => { return fail(test_num, "expected Err, got Ok") }
        Err(_) => { return 0 }
    }
}

// ============================================================================
// Test: Parse Basic Key-Value Pairs
// ============================================================================

fn test_string_value() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("name = \"Tom\"")
    match r {
        Ok(v) => {
            let s: ?string = toml_get_string(v, "name")
            match s {
                Some(val) => {
                    if val == "Tom" { return 0 }
                    return fail(1, "expected 'Tom'")
                }
                None => { return fail(1, "key not found") }
            }
        }
        Err(e) => {
            print("parse error: ")
            println(e.message)
            return fail(1, "parse failed")
        }
    }
}

fn test_integer_value() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("port = 8080")
    match r {
        Ok(v) => {
            let n: ?i64 = toml_get_integer(v, "port")
            match n {
                Some(val) => {
                    if val == 8080.as#[i64] { return 0 }
                    return fail(2, "expected 8080")
                }
                None => { return fail(2, "key not found") }
            }
        }
        Err(_) => { return fail(2, "parse failed") }
    }
}

fn test_negative_integer() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("offset = -42")
    match r {
        Ok(v) => {
            let n: ?i64 = toml_get_integer(v, "offset")
            match n {
                Some(val) => {
                    let expected: i64 = 0.as#[i64] - 42.as#[i64]
                    if val == expected { return 0 }
                    return fail(3, "expected -42")
                }
                None => { return fail(3, "key not found") }
            }
        }
        Err(_) => { return fail(3, "parse failed") }
    }
}

fn test_float_value() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("pi = 3.14")
    match r {
        Ok(v) => {
            let n: ?f64 = toml_get_float(v, "pi")
            match n {
                Some(val) => {
                    // Approximate comparison
                    if val > 3.13 and val < 3.15 { return 0 }
                    return fail(4, "expected ~3.14")
                }
                None => { return fail(4, "key not found") }
            }
        }
        Err(_) => { return fail(4, "parse failed") }
    }
}

fn test_bool_true() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("enabled = true")
    match r {
        Ok(v) => {
            let b: ?bool = toml_get_bool(v, "enabled")
            match b {
                Some(val) => {
                    if val { return 0 }
                    return fail(5, "expected true")
                }
                None => { return fail(5, "key not found") }
            }
        }
        Err(_) => { return fail(5, "parse failed") }
    }
}

fn test_bool_false() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("debug = false")
    match r {
        Ok(v) => {
            let b: ?bool = toml_get_bool(v, "debug")
            match b {
                Some(val) => {
                    if not val { return 0 }
                    return fail(6, "expected false")
                }
                None => { return fail(6, "key not found") }
            }
        }
        Err(_) => { return fail(6, "parse failed") }
    }
}

// ============================================================================
// Test: String Types
// ============================================================================

fn test_literal_string() -> i32 {
    let input: string = "path = 'C:\\Users\\me'"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let s: ?string = toml_get_string(v, "path")
            match s {
                Some(val) => {
                    // Literal strings have no escapes, backslashes are literal
                    if val == "C:\\Users\\me" { return 0 }
                    return fail(10, "literal string mismatch")
                }
                None => { return fail(10, "key not found") }
            }
        }
        Err(_) => { return fail(10, "parse failed") }
    }
}

fn test_escape_sequences() -> i32 {
    // Test that \n escape is properly decoded by comparing against a string with actual newline
    let r: Result#[TomlValue, TomlError] = toml_parse("msg = \"hello\\nworld\"")
    match r {
        Ok(v) => {
            let s: ?string = toml_get_string(v, "msg")
            match s {
                Some(val) => {
                    // Build expected string with actual newline
                    let expected: string = "hello" + from_byte(10.as#[u8]) + "world"
                    if val == expected { return 0 }
                    return fail(11, "escape decode mismatch")
                }
                None => { return fail(11, "key not found") }
            }
        }
        Err(_) => { return fail(11, "parse failed") }
    }
}

fn test_empty_string() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("empty = \"\"")
    match r {
        Ok(v) => {
            let s: ?string = toml_get_string(v, "empty")
            match s {
                Some(val) => {
                    if val == "" { return 0 }
                    return fail(12, "expected empty string")
                }
                None => { return fail(12, "key not found") }
            }
        }
        Err(_) => { return fail(12, "parse failed") }
    }
}

// ============================================================================
// Test: Sections (Tables)
// ============================================================================

fn test_simple_section() -> i32 {
    let input: string = "[server]\nhost = \"localhost\"\nport = 9090"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let server: ?TomlValue = toml_get(v, "server")
            match server {
                Some(sv) => {
                    let host: ?string = toml_get_string(sv, "host")
                    match host {
                        Some(h) => {
                            if h != "localhost" { return fail(20, "expected 'localhost'") }
                            let port: ?i64 = toml_get_integer(sv, "port")
                            match port {
                                Some(p) => {
                                    if p == 9090.as#[i64] { return 0 }
                                    return fail(20, "expected port 9090")
                                }
                                None => { return fail(20, "port not found") }
                            }
                        }
                        None => { return fail(20, "host not found") }
                    }
                }
                None => { return fail(20, "server section not found") }
            }
        }
        Err(_) => { return fail(20, "parse failed") }
    }
}

fn test_nested_sections() -> i32 {
    let input: string = "[database]\nname = \"mydb\"\n\n[database.connection]\nhost = \"db.local\"\nport = 5432"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let db: ?TomlValue = toml_get(v, "database")
            match db {
                Some(dbv) => {
                    let name: ?string = toml_get_string(dbv, "name")
                    match name {
                        Some(n) => {
                            if n != "mydb" { return fail(21, "expected 'mydb'") }
                        }
                        None => { return fail(21, "name not found") }
                    }
                    let conn: ?TomlValue = toml_get(dbv, "connection")
                    match conn {
                        Some(cv) => {
                            let host: ?string = toml_get_string(cv, "host")
                            match host {
                                Some(h) => {
                                    if h == "db.local" { return 0 }
                                    return fail(21, "expected 'db.local'")
                                }
                                None => { return fail(21, "host not found") }
                            }
                        }
                        None => { return fail(21, "connection section not found") }
                    }
                }
                None => { return fail(21, "database section not found") }
            }
        }
        Err(_) => { return fail(21, "parse failed") }
    }
}

fn test_multiple_sections() -> i32 {
    let input: string = "[alpha]\na = 1\n\n[beta]\nb = 2"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let alpha: ?TomlValue = toml_get(v, "alpha")
            match alpha {
                Some(av) => {
                    let a: ?i64 = toml_get_integer(av, "a")
                    match a {
                        Some(val) => {
                            if val != 1.as#[i64] { return fail(22, "expected a=1") }
                        }
                        None => { return fail(22, "a not found") }
                    }
                }
                None => { return fail(22, "alpha not found") }
            }
            let beta: ?TomlValue = toml_get(v, "beta")
            match beta {
                Some(bv) => {
                    let b: ?i64 = toml_get_integer(bv, "b")
                    match b {
                        Some(val) => {
                            if val == 2.as#[i64] { return 0 }
                            return fail(22, "expected b=2")
                        }
                        None => { return fail(22, "b not found") }
                    }
                }
                None => { return fail(22, "beta not found") }
            }
        }
        Err(_) => { return fail(22, "parse failed") }
    }
}

