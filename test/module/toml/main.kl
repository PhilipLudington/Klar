    let input: string = "server.host = \"localhost\"\nserver.port = 8080"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let server: ?TomlValue = toml_get(v, "server")
            match server {
                Some(sv) => {
                    let host: ?string = toml_get_string(sv, "host")
                    match host {
                        Some(h) => {
                            if h == "localhost" { return 0 }
                            return fail(30, "expected 'localhost'")
                        }
                        None => { return fail(30, "host not found") }
                    }
                }
                None => { return fail(30, "server not found") }
            }
        }
        Err(_) => { return fail(30, "parse failed") }
    }
}

// ============================================================================
// Test: Arrays
// ============================================================================

fn test_integer_array() -> i32 {
    let input: string = "ports = [80, 443, 8080]"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let arr: ?List#[TomlValue] = toml_get_array(v, "ports")
            match arr {
                Some(a) => {
                    if a.len() != 3 { return fail(40, "expected 3 elements") }
                    let first: TomlValue = a.get(0)!
                    match first {
                        TomlValue.Integer(n) => {
                            if n != 80.as#[i64] { return fail(40, "expected first=80") }
                        }
                        _ => { return fail(40, "expected Integer") }
                    }
                    let last: TomlValue = a.get(2)!
                    match last {
                        TomlValue.Integer(n) => {
                            if n != 8080.as#[i64] { return fail(40, "expected last=8080") }
                        }
                        _ => { return fail(40, "expected Integer") }
                    }
                    return 0
                }
                None => { return fail(40, "ports not found") }
            }
        }
        Err(_) => { return fail(40, "parse failed") }
    }
}

fn test_string_array() -> i32 {
    let input: string = "tags = [\"web\", \"api\", \"v2\"]"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let arr: ?List#[TomlValue] = toml_get_array(v, "tags")
            match arr {
                Some(a) => {
                    if a.len() != 3 { return fail(41, "expected 3 elements") }
                    let first: TomlValue = a.get(0)!
                    match first {
                        TomlValue.Str(s) => {
                            if s != "web" { return fail(41, "expected first='web'") }
                        }
                        _ => { return fail(41, "expected Str") }
                    }
                    let last: TomlValue = a.get(2)!
                    match last {
                        TomlValue.Str(s) => {
                            if s != "v2" { return fail(41, "expected last='v2'") }
                        }
                        _ => { return fail(41, "expected Str") }
                    }
                    return 0
                }
                None => { return fail(41, "tags not found") }
            }
        }
        Err(_) => { return fail(41, "parse failed") }
    }
}

fn test_empty_array() -> i32 {
    let input: string = "empty = []"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
