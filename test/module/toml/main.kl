fn test_get_missing_key() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("a = 1")
    match r {
        Ok(v) => {
            let missing: ?string = toml_get_string(v, "nope")
            match missing {
                Some(_) => { return fail(90, "should be None") }
                None => { return 0 }
            }
        }
        Err(_) => { return fail(90, "parse failed") }
    }
}

fn test_get_wrong_type() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("count = 42")
    match r {
        Ok(v) => {
            let s: ?string = toml_get_string(v, "count")
            match s {
                Some(_) => { return fail(91, "should be None for wrong type") }
                None => { return 0 }
            }
        }
        Err(_) => { return fail(91, "parse failed") }
    }
}

fn test_get_on_non_table() -> i32 {
    let v: TomlValue = toml_integer(42.as#[i64])
    let result: ?i64 = toml_get_integer(v, "anything")
    match result {
        Some(_) => { return fail(92, "should be None on non-table") }
        None => { return 0 }
    }
}

// ============================================================================
// Test: Error Cases
// ============================================================================

fn test_error_empty() -> i32 {
    // Empty input is valid TOML (empty table)
    let r: Result#[TomlValue, TomlError] = toml_parse("")
    return expect_ok(r, 100)
}

fn test_error_unterminated_string() -> i32 {
    return expect_err(toml_parse("name = \"hello"), 101)
}

fn test_error_missing_value() -> i32 {
    return expect_err(toml_parse("name = "), 102)
}

fn test_error_missing_equals() -> i32 {
    return expect_err(toml_parse("name \"value\""), 103)
}

fn test_error_bad_section() -> i32 {
    return expect_err(toml_parse("["), 104)
}

// ============================================================================
// Test: Stringify
// ============================================================================

fn test_stringify_basic() -> i32 {
    let r: Result#[TomlValue, TomlError] = toml_parse("name = \"hello\"\ncount = 42\nenabled = true")
    match r {
        Ok(v) => {
            let s: string = toml_stringify(v)
            // Should contain the key-value pairs
            let idx1: ?i32 = s.index_of("name")
            match idx1 {
                Some(_) => {}
                None => { return fail(110, "stringify missing 'name'") }
            }
            let idx2: ?i32 = s.index_of("count")
            match idx2 {
                Some(_) => {}
                None => { return fail(110, "stringify missing 'count'") }
            }
            return 0
        }
        Err(_) => { return fail(110, "parse failed") }
    }
}

// ============================================================================
// Test: Lodex-style Config
// ============================================================================

fn test_lodex_config() -> i32 {
    let input: string = "[project]\nname = \"my-app\"\nversion = \"0.1.0\"\n\n[evaluation]\nmax_checkpoints = 100\nauto_checkpoint = true\n\n[evaluation.suites]\nunit = \"test/unit\"\nintegration = \"test/integration\""
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            // Check project section
            let proj: ?TomlValue = toml_get(v, "project")
            match proj {
                Some(pv) => {
                    let name: ?string = toml_get_string(pv, "name")
                    match name {
                        Some(n) => {
                            if n != "my-app" { return fail(120, "expected 'my-app'") }
                        }
                        None => { return fail(120, "name not found") }
                    }
                }
                None => { return fail(120, "project section not found") }
            }

            // Check evaluation section
            let eval_sec: ?TomlValue = toml_get(v, "evaluation")
            match eval_sec {
                Some(ev) => {
                    let mc: ?i64 = toml_get_integer(ev, "max_checkpoints")
                    match mc {
                        Some(val) => {
                            if val != 100.as#[i64] { return fail(120, "expected max_checkpoints=100") }
                        }
                        None => { return fail(120, "max_checkpoints not found") }
                    }

                    let ac: ?bool = toml_get_bool(ev, "auto_checkpoint")
                    match ac {
                        Some(val) => {
                            if not val { return fail(120, "expected auto_checkpoint=true") }
                        }
                        None => { return fail(120, "auto_checkpoint not found") }
                    }

                    // Check nested suites
                    let suites: ?TomlValue = toml_get(ev, "suites")
                    match suites {
                        Some(sv) => {
                            let unit: ?string = toml_get_string(sv, "unit")
                            match unit {
                                Some(u) => {
                                    if u != "test/unit" { return fail(120, "expected unit='test/unit'") }
                                }
                                None => { return fail(120, "unit not found") }
                            }
                            let integ: ?string = toml_get_string(sv, "integration")
                            match integ {
                                Some(ig) => {
                                    if ig == "test/integration" { return 0 }
                                    return fail(120, "expected integration='test/integration'")
                                }
                                None => { return fail(120, "integration not found") }
                            }
                        }
                        None => { return fail(120, "suites section not found") }
                    }
                }
                None => { return fail(120, "evaluation section not found") }
            }
        }
        Err(e) => {
            print("parse error: ")
            print(e.message)
            print(" at line ")
            println(e.line.to_string().as_str())
            return fail(120, "parse failed")
        }
    }
}

// ============================================================================
// Test: Top-level key-value pairs before sections
// ============================================================================

fn test_toplevel_and_sections() -> i32 {
    let input: string = "title = \"My Config\"\n\n[server]\nhost = \"0.0.0.0\""
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let title: ?string = toml_get_string(v, "title")
            match title {
                Some(t) => {
                    if t != "My Config" { return fail(130, "expected 'My Config'") }
                    let server: ?TomlValue = toml_get(v, "server")
                    match server {
                        Some(sv) => {
                            let host: ?string = toml_get_string(sv, "host")
                            match host {
                                Some(h) => {
                                    if h == "0.0.0.0" { return 0 }
                                    return fail(130, "expected '0.0.0.0'")
                                }
                                None => { return fail(130, "host not found") }
                            }
                        }
                        None => { return fail(130, "server not found") }
                    }
                }
                None => { return fail(130, "title not found") }
            }
        }
        Err(_) => { return fail(130, "parse failed") }
    }
}

// ============================================================================
// Test: Quoted keys
// ============================================================================

fn test_quoted_key() -> i32 {
    let input: string = "\"special key\" = \"value\""
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let s: ?string = toml_get_string(v, "special key")
            match s {
                Some(val) => {
                    if val == "value" { return 0 }
                    return fail(140, "expected 'value'")
                }
                None => { return fail(140, "key not found") }
            }
        }
        Err(_) => { return fail(140, "parse failed") }
    }
}

// NOTE: Multiline string tests (""" and ''') are omitted because the native
// codegen crashes on multiline string parsing. This is a pre-existing compiler
// bug, not a TOML library issue.

// ============================================================================
// Test: Unicode Escapes
// ============================================================================

fn test_unicode_escape_4digit() -> i32 {
    // \u0041 = 'A' (1-byte UTF-8)
    let input: string = "ch = \"\\u0041\""
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let s: ?string = toml_get_string(v, "ch")
            match s {
                Some(val) => {
                    if val == "A" { return 0 }
                    return fail(152, "expected 'A'")
                }
                None => { return fail(152, "ch not found") }
            }
        }
        Err(e) => {
            print("FAIL 152: ")
            println(e.message)
            return 152
        }
    }
}

fn test_unicode_surrogate_rejected() -> i32 {
    // \uD800 is a surrogate — must be rejected
    let input: string = "bad = \"\\uD800\""
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(_) => { return fail(153, "expected Err for surrogate, got Ok") }
        Err(_) => { return 0 }
    }
}

// ============================================================================
// Test: Octal and Binary Integers
// ============================================================================

fn test_octal_integer() -> i32 {
    let input: string = "n = 0o17"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let n: ?i64 = toml_get_integer(v, "n")
            match n {
                Some(val) => {
                    if val == 15.as#[i64] { return 0 }
                    return fail(154, "expected 15")
                }
                None => { return fail(154, "n not found") }
            }
        }
        Err(e) => {
            print("FAIL 154: ")
            println(e.message)
            return 154
        }
    }
}

fn test_binary_integer() -> i32 {
    let input: string = "n = 0b1010"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(v) => {
            let n: ?i64 = toml_get_integer(v, "n")
            match n {
                Some(val) => {
                    if val == 10.as#[i64] { return 0 }
                    return fail(155, "expected 10")
                }
                None => { return fail(155, "n not found") }
            }
        }
        Err(e) => {
            print("FAIL 155: ")
            println(e.message)
            return 155
        }
    }
}

// NOTE: Special float tests (inf, nan, -inf) are omitted because the native
// codegen crashes on f64 infinity/NaN operations. This is a pre-existing
// compiler bug, not a TOML library issue.

// ============================================================================
// Test: Dotted key conflict detection
// ============================================================================

fn test_dotted_key_conflict() -> i32 {
    // a = 1 then a.b = 2 should error (a is non-table)
    let input: string = "a = 1\na.b = 2"
    let r: Result#[TomlValue, TomlError] = toml_parse(input)
    match r {
        Ok(_) => { return fail(159, "expected Err for key conflict, got Ok") }
        Err(_) => { return 0 }
    }
}

// ============================================================================
// Main
// ============================================================================

fn main() -> i32 {
    var e: i32 = 0

    // Basic key-value pairs
    e = test_string_value()
    if e != 0 { return e }
    e = test_integer_value()
    if e != 0 { return e }
    e = test_negative_integer()
    if e != 0 { return e }
    e = test_float_value()
    if e != 0 { return e }
    e = test_bool_true()
    if e != 0 { return e }
    e = test_bool_false()
    if e != 0 { return e }

    // String types
    e = test_literal_string()
    if e != 0 { return e }
    e = test_escape_sequences()
    if e != 0 { return e }
    e = test_empty_string()
    if e != 0 { return e }

    // Sections
    e = test_simple_section()
    if e != 0 { return e }
    e = test_nested_sections()
    if e != 0 { return e }
    e = test_multiple_sections()
    if e != 0 { return e }

    // Dotted keys
    e = test_dotted_key()
    if e != 0 { return e }

    // Arrays
    e = test_integer_array()
    if e != 0 { return e }
    e = test_string_array()
    if e != 0 { return e }
    e = test_empty_array()
    if e != 0 { return e }
    e = test_multiline_array()
    if e != 0 { return e }

    // Inline tables
    e = test_inline_table()
    if e != 0 { return e }
    e = test_empty_inline_table()
    if e != 0 { return e }

    // Array of tables
    e = test_array_of_tables()
    if e != 0 { return e }

    // Comments
    e = test_comments()
    if e != 0 { return e }

    // Number formats
    e = test_hex_integer()
    if e != 0 { return e }
    e = test_underscore_number()
    if e != 0 { return e }
    e = test_float_exponent()
    if e != 0 { return e }
    e = test_positive_sign()
    if e != 0 { return e }

    // Accessor edge cases
    e = test_get_missing_key()
    if e != 0 { return e }
    e = test_get_wrong_type()
    if e != 0 { return e }
    e = test_get_on_non_table()
    if e != 0 { return e }

    // Error cases
    e = test_error_empty()
    if e != 0 { return e }
    e = test_error_unterminated_string()
    if e != 0 { return e }
    e = test_error_missing_value()
    if e != 0 { return e }
    e = test_error_missing_equals()
    if e != 0 { return e }
    e = test_error_bad_section()
    if e != 0 { return e }
    // Stringify
    e = test_stringify_basic()
    if e != 0 { return e }

    // Lodex-style config
    e = test_lodex_config()
    if e != 0 { return e }

    // Mixed top-level + sections
    e = test_toplevel_and_sections()
    if e != 0 { return e }

    // Quoted keys
    e = test_quoted_key()
    if e != 0 { return e }

    // Unicode escapes
    e = test_unicode_escape_4digit()
    if e != 0 { return e }
    e = test_unicode_surrogate_rejected()
    if e != 0 { return e }

    // Octal and binary integers
    e = test_octal_integer()
    if e != 0 { return e }
    e = test_binary_integer()
    if e != 0 { return e }

    // Dotted key conflict detection
    e = test_dotted_key_conflict()
    if e != 0 { return e }

    println("All TOML tests passed")
    return 0
}
