fn test_yes_no_booleans() -> i32 {
    let input: string = "active: yes\ndisabled: no"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let active: ?bool = yaml_get_bool(v, "active")
            match active {
                Some(val) => {
                    if not val { return fail(29, "expected yes=true") }
                }
                None => { return fail(29, "active not found") }
            }
            let disabled: ?bool = yaml_get_bool(v, "disabled")
            match disabled {
                Some(val) => {
                    if val { return fail(29, "expected no=false") }
                }
                None => { return fail(29, "disabled not found") }
            }
            return 0
        }
        Err(_) => { return fail(29, "parse failed") }
    }
}

// ============================================================================
// Test: Stringify
// ============================================================================

fn test_stringify_scalars() -> i32 {
    let s: string = yaml_stringify(YamlValue::Str("hello"))
    if s != "hello\n" { return fail(30, "expected 'hello\\n'") }

    let n: string = yaml_stringify(YamlValue::Int(42.as#[i64]))
    if n != "42\n" { return fail(30, "expected '42\\n'") }

    let b: string = yaml_stringify(YamlValue::Bool(true))
    if b != "true\n" { return fail(30, "expected 'true\\n'") }

    let null_s: string = yaml_stringify(YamlValue::Null)
    if null_s != "null\n" { return fail(30, "expected 'null\\n'") }

    return 0
}

fn test_stringify_mapping() -> i32 {
    let input: string = "name: Alice\nage: 30"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let output: string = yaml_stringify(v)
            // Verify output parses back correctly
            let r2: Result#[YamlValue, YamlError] = yaml_parse(output)
            match r2 {
                Ok(v2) => {
                    let name: ?string = yaml_get_string(v2, "name")
                    match name {
                        Some(val) => {
                            if val != "Alice" { return fail(31, "round-trip name failed") }
                        }
                        None => { return fail(31, "name lost in round-trip") }
                    }
                    let age: ?i64 = yaml_get_int(v2, "age")
                    match age {
                        Some(val) => {
                            if val != 30.as#[i64] { return fail(31, "round-trip age failed") }
                        }
                        None => { return fail(31, "age lost in round-trip") }
                    }
                    return 0
                }
                Err(_) => { return fail(31, "round-trip parse failed") }
            }
        }
        Err(_) => { return fail(31, "parse failed") }
    }
}

fn test_stringify_sequence() -> i32 {
    let input: string = "items:\n  - 1\n  - 2\n  - 3"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let output: string = yaml_stringify(v)
            let r2: Result#[YamlValue, YamlError] = yaml_parse(output)
            match r2 {
                Ok(v2) => {
                    let seq: ?List#[YamlValue] = yaml_get_sequence(v2, "items")
                    match seq {
                        Some(items) => {
                            if items.len() != 3 { return fail(32, "round-trip lost items") }
                            return 0
                        }
                        None => { return fail(32, "items lost in round-trip") }
                    }
                }
                Err(_) => { return fail(32, "round-trip parse failed") }
            }
        }
        Err(_) => { return fail(32, "parse failed") }
    }
}

fn test_stringify_empty_collections() -> i32 {
    let empty_seq: string = yaml_stringify(YamlValue::Sequence(List.new#[YamlValue]()))
    if empty_seq != "[]\n" { return fail(33, "expected '[]\\n'") }

    return 0
}

// ============================================================================
// Test: Error Cases
// ============================================================================

fn test_error_unterminated_double_quote() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("msg: \"unterminated")
    return expect_err(r, 34)
}

fn test_error_unterminated_single_quote() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("msg: 'unterminated")
    return expect_err(r, 35)
}

// ============================================================================
// Test: Complex Real-World Config
// ============================================================================

fn test_server_config() -> i32 {
    let input: string = "server:\n  host: 0.0.0.0\n  port: 3000\n  debug: false\ndatabase:\n  host: localhost\n  port: 5432\n  name: myapp"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let server: ?YamlValue = yaml_get(v, "server")
            match server {
                Some(srv) => {
                    let port: ?i64 = yaml_get_int(srv, "port")
                    match port {
                        Some(val) => {
                            if val != 3000.as#[i64] { return fail(36, "expected server port 3000") }
                        }
                        None => { return fail(36, "server port not found") }
                    }
                }
                None => { return fail(36, "server not found") }
            }
            let db: ?YamlValue = yaml_get(v, "database")
            match db {
                Some(d) => {
                    let name: ?string = yaml_get_string(d, "name")
                    match name {
                        Some(val) => {
                            if val != "myapp" { return fail(36, "expected db name 'myapp'") }
                        }
                        None => { return fail(36, "db name not found") }
                    }
                }
                None => { return fail(36, "database not found") }
            }
            return 0
        }
        Err(_) => { return fail(36, "parse failed") }
    }
}

// ============================================================================
// Test: Mixed Inline and Block
// ============================================================================

fn test_mixed_inline_and_block() -> i32 {
    let input: string = "name: Alice\ntags: [admin, user]\nsettings:\n  theme: dark"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let name: ?string = yaml_get_string(v, "name")
            match name {
                Some(val) => {
                    if val != "Alice" { return fail(37, "expected 'Alice'") }
                }
                None => { return fail(37, "name not found") }
            }
            let tags: ?List#[YamlValue] = yaml_get_sequence(v, "tags")
            match tags {
                Some(items) => {
                    if items.len() != 2 { return fail(37, "expected 2 tags") }
                }
                None => { return fail(37, "tags not found") }
            }
            let settings: ?YamlValue = yaml_get(v, "settings")
            match settings {
                Some(s) => {
                    let theme: ?string = yaml_get_string(s, "theme")
                    match theme {
                        Some(val) => {
                            if val != "dark" { return fail(37, "expected 'dark'") }
                        }
                        None => { return fail(37, "theme not found") }
                    }
                }
                None => { return fail(37, "settings not found") }
            }
            return 0
        }
        Err(_) => { return fail(37, "parse failed") }
    }
}

// ============================================================================
// Test: Flow Sequence with Strings
// ============================================================================

fn test_flow_sequence_strings() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("tags: [\"foo\", 'bar', baz]")
    match r {
        Ok(v) => {
            let tags: ?List#[YamlValue] = yaml_get_sequence(v, "tags")
            match tags {
                Some(items) => {
                    if items.len() != 3 { return fail(38, "expected 3 items") }
                    let first: YamlValue = items.get(0)!
                    match first {
                        YamlValue.Str(s) => {
                            if s != "foo" { return fail(38, "expected 'foo'") }
                        }
                        _ => { return fail(38, "expected string") }
                    }
                    return 0
                }
                None => { return fail(38, "tags not found") }
            }
        }
        Err(_) => { return fail(38, "parse failed") }
    }
}

// ============================================================================
// Test: Deeply Nested
// ============================================================================

fn test_deeply_nested() -> i32 {
    let input: string = "a:\n  b:\n    c:\n      d: deep"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let a: ?YamlValue = yaml_get(v, "a")
            match a {
                Some(av) => {
                    let b: ?YamlValue = yaml_get(av, "b")
                    match b {
                        Some(bv) => {
                            let c: ?YamlValue = yaml_get(bv, "c")
                            match c {
                                Some(cv) => {
                                    let d: ?string = yaml_get_string(cv, "d")
                                    match d {
                                        Some(val) => {
                                            if val == "deep" { return 0 }
                                            return fail(39, "expected 'deep'")
                                        }
                                        None => { return fail(39, "d not found") }
                                    }
                                }
                                None => { return fail(39, "c not found") }
                            }
                        }
                        None => { return fail(39, "b not found") }
                    }
                }
                None => { return fail(39, "a not found") }
            }
        }
        Err(_) => { return fail(39, "parse failed") }
    }
}

// ============================================================================
// Main Test Runner
// ============================================================================

fn main() -> i32 {
    var e: i32 = 0

    // Scalars
    e = test_string_value()
    if e != 0 { return e }
    e = test_integer_value()
    if e != 0 { return e }
    e = test_negative_integer()
    if e != 0 { return e }
    e = test_float_value()
    if e != 0 { return e }
    e = test_bool_true()
    if e != 0 { return e }
    e = test_bool_false()
    if e != 0 { return e }
    e = test_null_value()
    if e != 0 { return e }
    e = test_tilde_null()
    if e != 0 { return e }

    // Quoted strings
    e = test_double_quoted_string()
    if e != 0 { return e }
    e = test_single_quoted_string()
    if e != 0 { return e }
    e = test_escape_sequences()
    if e != 0 { return e }

    // Block sequences
    e = test_simple_sequence()
    if e != 0 { return e }
    e = test_sequence_of_integers()
    if e != 0 { return e }
    e = test_top_level_sequence()
    if e != 0 { return e }

    // Block mappings
    e = test_simple_mapping()
    if e != 0 { return e }
    e = test_nested_mapping()
    if e != 0 { return e }

    // Nested structures
    e = test_sequence_of_mappings()
    if e != 0 { return e }
    e = test_mapping_of_sequences()
    if e != 0 { return e }

    // Flow collections
    e = test_flow_sequence()
    if e != 0 { return e }
    e = test_flow_mapping()
    if e != 0 { return e }
    e = test_empty_flow_sequence()
    if e != 0 { return e }
    e = test_empty_flow_mapping()
    if e != 0 { return e }

    // Comments
    e = test_comments()
    if e != 0 { return e }

    // Document marker
    e = test_document_start()
    if e != 0 { return e }

    // Empty input
    e = test_empty_input()
    if e != 0 { return e }

    // Accessor edge cases
    e = test_get_missing_key()
    if e != 0 { return e }
    e = test_get_wrong_type()
    if e != 0 { return e }
    e = test_get_on_non_mapping()
    if e != 0 { return e }

    // Boolean variants
    e = test_yes_no_booleans()
    if e != 0 { return e }

    // Stringify
    e = test_stringify_scalars()
    if e != 0 { return e }
    e = test_stringify_mapping()
    if e != 0 { return e }
    e = test_stringify_sequence()
    if e != 0 { return e }
    e = test_stringify_empty_collections()
    if e != 0 { return e }

    // Error cases
    e = test_error_unterminated_double_quote()
    if e != 0 { return e }
    e = test_error_unterminated_single_quote()
    if e != 0 { return e }

    // Complex configs
    e = test_server_config()
    if e != 0 { return e }

    // Mixed
    e = test_mixed_inline_and_block()
    if e != 0 { return e }

    // Flow with strings
    e = test_flow_sequence_strings()
    if e != 0 { return e }

    // Deeply nested
    e = test_deeply_nested()
    if e != 0 { return e }

    println("All YAML tests passed")
    return 0
}
