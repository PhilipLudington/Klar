// test/module/yaml/main.kl - Comprehensive tests for stdlib/yaml.kl
// Tests: scalars, sequences, mappings, nested structures, flow collections,
//        block scalars, comments, accessors, error handling, stringify round-trip
// Returns 0 on success, non-zero test number on failure

import stdlib.yaml.*

// ============================================================================
// Test Helpers
// ============================================================================

fn fail(test_num: i32, msg: string) -> i32 {
    print("FAIL test ")
    print(test_num.to_string().as_str())
    print(": ")
    println(msg)
    return test_num
}

fn expect_str(actual: string, expected: string, test_num: i32) -> i32 {
    if actual != expected {
        print("FAIL test ")
        print(test_num.to_string().as_str())
        print(": expected '")
        print(expected)
        print("' got '")
        print(actual)
        println("'")
        return test_num
    }
    return 0
}

fn expect_ok(r: Result#[YamlValue, YamlError], test_num: i32) -> i32 {
    match r {
        Ok(_) => { return 0 }
        Err(e) => {
            print("FAIL test ")
            print(test_num.to_string().as_str())
            print(": expected Ok, got Err: ")
            print(e.message)
            print(" at line ")
            println(e.line.to_string().as_str())
            return test_num
        }
    }
}

fn expect_err(r: Result#[YamlValue, YamlError], test_num: i32) -> i32 {
    match r {
        Ok(_) => { return fail(test_num, "expected Err, got Ok") }
        Err(_) => { return 0 }
    }
}

// ============================================================================
// Test: Scalar Types
// ============================================================================

fn test_string_value() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("name: Tom")
    match r {
        Ok(v) => {
            let s: ?string = yaml_get_string(v, "name")
            match s {
                Some(val) => {
                    if val == "Tom" { return 0 }
                    return fail(1, "expected 'Tom'")
                }
                None => { return fail(1, "key not found") }
            }
        }
        Err(e) => {
            print("parse error: ")
            println(e.message)
            return fail(1, "parse failed")
        }
    }
}

fn test_integer_value() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("port: 8080")
    match r {
        Ok(v) => {
            let n: ?i64 = yaml_get_int(v, "port")
            match n {
                Some(val) => {
                    if val == 8080.as#[i64] { return 0 }
                    return fail(2, "expected 8080")
                }
                None => { return fail(2, "key not found") }
            }
        }
        Err(_) => { return fail(2, "parse failed") }
    }
}

fn test_negative_integer() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("offset: -42")
    match r {
        Ok(v) => {
            let n: ?i64 = yaml_get_int(v, "offset")
            match n {
                Some(val) => {
                    if val == -42.as#[i64] { return 0 }
                    return fail(3, "expected -42")
                }
                None => { return fail(3, "key not found") }
            }
        }
        Err(_) => { return fail(3, "parse failed") }
    }
}

fn test_float_value() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("pi: 3.14")
    match r {
        Ok(v) => {
            let n: ?f64 = yaml_get_float(v, "pi")
            match n {
                Some(val) => {
                    if val > 3.13 and val < 3.15 { return 0 }
                    return fail(4, "expected ~3.14")
                }
                None => { return fail(4, "key not found") }
            }
        }
        Err(_) => { return fail(4, "parse failed") }
    }
}

fn test_bool_true() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("enabled: true")
    match r {
        Ok(v) => {
            let b: ?bool = yaml_get_bool(v, "enabled")
            match b {
                Some(val) => {
                    if val { return 0 }
                    return fail(5, "expected true")
