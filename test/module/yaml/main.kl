                None => { return fail(5, "key not found") }
            }
        }
        Err(_) => { return fail(5, "parse failed") }
    }
}

fn test_bool_false() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("debug: false")
    match r {
        Ok(v) => {
            let b: ?bool = yaml_get_bool(v, "debug")
            match b {
                Some(val) => {
                    if not val { return 0 }
                    return fail(6, "expected false")
                }
                None => { return fail(6, "key not found") }
            }
        }
        Err(_) => { return fail(6, "parse failed") }
