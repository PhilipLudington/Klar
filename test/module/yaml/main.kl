                None => { return fail(9, "key not found") }
            }
        }
        Err(_) => { return fail(9, "parse failed") }
    }
}

fn test_single_quoted_string() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("msg: 'hello world'")
