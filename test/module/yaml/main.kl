                None => { return fail(11, "key not found") }
            }
        }
        Err(_) => { return fail(11, "parse failed") }
    }
}

// ============================================================================
// Test: Block Sequences
// ============================================================================

fn test_simple_sequence() -> i32 {
    let input: string = "fruits:\n  - apple\n  - banana\n  - cherry"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let seq: ?List#[YamlValue] = yaml_get_sequence(v, "fruits")
            match seq {
                Some(items) => {
                    if items.len() != 3 {
                        return fail(12, "expected 3 items")
                    }
                    let first: YamlValue = items.get(0)!
                    match first {
                        YamlValue.Str(s) => {
                            if s != "apple" { return fail(12, "expected 'apple'") }
                        }
                        _ => { return fail(12, "expected string") }
                    }
                    return 0
                }
                None => { return fail(12, "key not found") }
            }
        }
        Err(e) => {
            print("parse error: ")
            println(e.message)
            return fail(12, "parse failed")
        }
    }
}

fn test_sequence_of_integers() -> i32 {
    let input: string = "numbers:\n  - 1\n  - 2\n  - 3"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let seq: ?List#[YamlValue] = yaml_get_sequence(v, "numbers")
            match seq {
                Some(items) => {
                    if items.len() != 3 {
                        return fail(13, "expected 3 items")
                    }
                    let second: YamlValue = items.get(1)!
                    match second {
                        YamlValue.Int(n) => {
                            if n != 2.as#[i64] { return fail(13, "expected 2") }
                        }
                        _ => { return fail(13, "expected Int") }
                    }
                    return 0
                }
                None => { return fail(13, "key not found") }
            }
        }
        Err(_) => { return fail(13, "parse failed") }
    }
}

fn test_top_level_sequence() -> i32 {
    let input: string = "- one\n- two\n- three"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            match v {
                YamlValue.Sequence(items) => {
                    if items.len() != 3 {
                        return fail(14, "expected 3 items")
                    }
                    return 0
                }
                _ => { return fail(14, "expected Sequence") }
            }
        }
        Err(_) => { return fail(14, "parse failed") }
    }
}

// ============================================================================
// Test: Block Mappings
// ============================================================================

fn test_simple_mapping() -> i32 {
    let input: string = "name: Alice\nage: 30\ncity: Berlin"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let name: ?string = yaml_get_string(v, "name")
            match name {
                Some(val) => {
                    if val != "Alice" { return fail(15, "expected 'Alice'") }
                }
                None => { return fail(15, "name not found") }
            }
            let age: ?i64 = yaml_get_int(v, "age")
            match age {
                Some(val) => {
                    if val != 30.as#[i64] { return fail(15, "expected 30") }
                }
                None => { return fail(15, "age not found") }
            }
            return 0
        }
        Err(_) => { return fail(15, "parse failed") }
    }
}

fn test_nested_mapping() -> i32 {
    let input: string = "server:\n  host: localhost\n  port: 8080"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let server: ?YamlValue = yaml_get(v, "server")
            match server {
                Some(srv) => {
                    let host: ?string = yaml_get_string(srv, "host")
                    match host {
                        Some(val) => {
                            if val != "localhost" { return fail(16, "expected 'localhost'") }
                        }
                        None => { return fail(16, "host not found") }
                    }
                    let port: ?i64 = yaml_get_int(srv, "port")
                    match port {
                        Some(val) => {
                            if val != 8080.as#[i64] { return fail(16, "expected 8080") }
                        }
                        None => { return fail(16, "port not found") }
                    }
                    return 0
                }
                None => { return fail(16, "server not found") }
            }
        }
        Err(_) => { return fail(16, "parse failed") }
    }
}

// ============================================================================
// Test: Nested Structures
// ============================================================================

fn test_sequence_of_mappings() -> i32 {
    let input: string = "users:\n  - name: Alice\n    age: 30\n  - name: Bob\n    age: 25"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let users: ?List#[YamlValue] = yaml_get_sequence(v, "users")
            match users {
                Some(items) => {
                    if items.len() != 2 {
                        return fail(17, "expected 2 users")
                    }
                    let first: YamlValue = items.get(0)!
                    let name: ?string = yaml_get_string(first, "name")
                    match name {
                        Some(val) => {
                            if val != "Alice" { return fail(17, "expected 'Alice'") }
                        }
                        None => { return fail(17, "name not found") }
                    }
                    let second: YamlValue = items.get(1)!
                    let bob_age: ?i64 = yaml_get_int(second, "age")
                    match bob_age {
                        Some(val) => {
                            if val != 25.as#[i64] { return fail(17, "expected 25") }
                        }
                        None => { return fail(17, "bob age not found") }
                    }
                    return 0
                }
                None => { return fail(17, "users not found") }
            }
        }
        Err(e) => {
            print("parse error: ")
            println(e.message)
            return fail(17, "parse failed")
        }
    }
}

fn test_mapping_of_sequences() -> i32 {
    let input: string = "colors:\n  - red\n  - green\nsizes:\n  - small\n  - large"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let colors: ?List#[YamlValue] = yaml_get_sequence(v, "colors")
            match colors {
                Some(items) => {
                    if items.len() != 2 { return fail(18, "expected 2 colors") }
                }
                None => { return fail(18, "colors not found") }
            }
            let sizes: ?List#[YamlValue] = yaml_get_sequence(v, "sizes")
            match sizes {
                Some(items) => {
                    if items.len() != 2 { return fail(18, "expected 2 sizes") }
                }
                None => { return fail(18, "sizes not found") }
            }
            return 0
        }
        Err(_) => { return fail(18, "parse failed") }
    }
}

// ============================================================================
// Test: Flow Collections
// ============================================================================

fn test_flow_sequence() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("items: [1, 2, 3]")
    match r {
        Ok(v) => {
            let seq: ?List#[YamlValue] = yaml_get_sequence(v, "items")
            match seq {
                Some(items) => {
                    if items.len() != 3 { return fail(19, "expected 3 items") }
                    let first: YamlValue = items.get(0)!
                    match first {
                        YamlValue.Int(n) => {
                            if n != 1.as#[i64] { return fail(19, "expected 1") }
                        }
                        _ => { return fail(19, "expected Int") }
                    }
                    return 0
                }
                None => { return fail(19, "key not found") }
            }
        }
        Err(_) => { return fail(19, "parse failed") }
    }
}

fn test_flow_mapping() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("point: {x: 1, y: 2}")
    match r {
        Ok(v) => {
            let point: ?YamlValue = yaml_get(v, "point")
            match point {
                Some(p) => {
                    let x: ?i64 = yaml_get_int(p, "x")
                    match x {
                        Some(val) => {
                            if val != 1.as#[i64] { return fail(20, "expected x=1") }
                        }
                        None => { return fail(20, "x not found") }
                    }
                    let y: ?i64 = yaml_get_int(p, "y")
                    match y {
                        Some(val) => {
                            if val != 2.as#[i64] { return fail(20, "expected y=2") }
                        }
                        None => { return fail(20, "y not found") }
                    }
                    return 0
                }
                None => { return fail(20, "point not found") }
            }
        }
        Err(_) => { return fail(20, "parse failed") }
    }
}

fn test_empty_flow_sequence() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("items: []")
    match r {
        Ok(v) => {
            let seq: ?List#[YamlValue] = yaml_get_sequence(v, "items")
            match seq {
                Some(items) => {
                    if items.len() != 0 { return fail(21, "expected empty") }
                    return 0
                }
                None => { return fail(21, "key not found") }
            }
        }
        Err(_) => { return fail(21, "parse failed") }
    }
}

fn test_empty_flow_mapping() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("data: {}")
    match r {
        Ok(v) => {
            let data: ?YamlValue = yaml_get(v, "data")
            match data {
                Some(d) => {
                    match d {
                        YamlValue.Mapping(_) => { return 0 }
                        _ => { return fail(22, "expected Mapping") }
                    }
                }
                None => { return fail(22, "key not found") }
            }
        }
        Err(_) => { return fail(22, "parse failed") }
    }
}

// ============================================================================
// Test: Comments
// ============================================================================

fn test_comments() -> i32 {
    let input: string = "# This is a comment\nname: Alice  # inline comment\n# Another comment\nage: 30"
    let r: Result#[YamlValue, YamlError] = yaml_parse(input)
    match r {
        Ok(v) => {
            let name: ?string = yaml_get_string(v, "name")
            match name {
                Some(val) => {
                    if val != "Alice" { return fail(23, "expected 'Alice'") }
                }
                None => { return fail(23, "name not found") }
            }
            let age: ?i64 = yaml_get_int(v, "age")
            match age {
                Some(val) => {
                    if val != 30.as#[i64] { return fail(23, "expected 30") }
                }
                None => { return fail(23, "age not found") }
            }
            return 0
        }
        Err(_) => { return fail(23, "parse failed") }
    }
}

