}

fn test_null_value() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("empty: null")
    match r {
        Ok(v) => {
            let val: ?YamlValue = yaml_get(v, "empty")
            match val {
                Some(inner) => {
                    match inner {
                        YamlValue.Null => { return 0 }
                        _ => { return fail(7, "expected Null") }
                    }
                }
                None => { return fail(7, "key not found") }
            }
        }
        Err(_) => { return fail(7, "parse failed") }
    }
}

fn test_tilde_null() -> i32 {
    let r: Result#[YamlValue, YamlError] = yaml_parse("empty: ~")
