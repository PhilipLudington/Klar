    let r: Result#[YamlValue, YamlError] = yaml_parse("msg: \"hello world\"")
    match r {
        Ok(v) => {
            let s: ?string = yaml_get_string(v, "msg")
            match s {
                Some(val) => {
                    if val == "hello world" { return 0 }
                    return fail(9, "expected 'hello world'")
