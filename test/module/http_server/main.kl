// Test HTTP server library
// Uses Klar TCP client directly (no curl/process_spawn) for cross-platform compatibility.
// Expected exit code: 0

import stdlib.http_server.*

fn find_str(s: string, needle: string, start: i32) -> i32 {
    let slen: i32 = s.len()
    let nlen: i32 = needle.len()
    if nlen == 0 { return start }
    let limit: i32 = slen - nlen + 1
    for i: i32 in start..limit {
        if s.slice(i, i + nlen) == needle {
            return i
        }
    }
    return -1
}

fn main() -> i32 {
    // Test 1: Parse HTTP request
    let raw: string = "GET /test HTTP/1.1\r\nHost: localhost\r\nContent-Type: text/plain\r\n\r\nhello"
    let pr: Result#[HttpRequest, string] = parse_http_request(raw)
    if not pr.is_ok() {
        println("parse failed")
        return 1
    }
    let parsed_req: HttpRequest = pr!
    assert_eq(parsed_req.method, "GET")
    assert_eq(parsed_req.path, "/test")
    assert_eq(parsed_req.body, "hello")

    // Test 2: Route matching — exact
    let params1: Map#[string, string] = match_route("/health", "/health")
    assert_eq(route_matched(params1), true)

    // Test 3: Route matching — path parameter
    // Build pattern with braces (can't use string interpolation for literal braces)
    let lbrace: string = from_byte(123.as#[u8])
    let rbrace: string = from_byte(125.as#[u8])
    let pattern: string = "/api/users/" + lbrace + "user_id" + rbrace
    let params2: Map#[string, string] = match_route(pattern, "/api/users/42")
    assert_eq(route_matched(params2), true)
    let uid: ?string = params2.get("user_id")
    match uid {
        Some(v) => { assert_eq(v, "42") }
        None => { return 3 }
    }

    // Test 4: Route non-match
    let params3: Map#[string, string] = match_route("/api/items", "/api/users")
    assert_eq(route_matched(params3), false)

    // Test 5: Serialize response
    let resp: HttpResponse = http_ok("test body")
    let serialized: string = serialize_response(resp)
    assert_eq(serialized.slice(0, 15), "HTTP/1.1 200 OK")

    // Test 6: Simple GET via Klar TCP client
    let lr1: Result#[TcpListener, IoError] = tcp_listen("127.0.0.1", 19877)
    if not lr1.is_ok() {
        println("listen failed")
        return 6
    }
    let listener1: TcpListener = lr1!

    // Connect client and send raw HTTP GET request
    let cr1: Result#[TcpStream, IoError] = tcp_connect("127.0.0.1", 19877)
    if not cr1.is_ok() {
        tcp_listener_close(listener1)
        println("connect failed")
        return 6
    }
    let client1: TcpStream = cr1!
    let _w1: Result#[i32, IoError] = tcp_write(client1, "GET /hello HTTP/1.1\r\nHost: 127.0.0.1\r\nConnection: close\r\n\r\n")

    // Accept and process request on server side
    let ar1: Result#[HttpConnection, string] = http_server_accept_on(listener1)
    if not ar1.is_ok() {
        tcp_close(client1)
        tcp_listener_close(listener1)
        println("accept failed")
        return 7
    }
    let conn1: HttpConnection = ar1!

    assert_eq(conn1.request.method, "GET")
    assert_eq(conn1.request.path, "/hello")

    http_server_respond(conn1, http_ok("Hello, World!"))

    // Read response on client side
    let rr1: Result#[string, IoError] = tcp_read(client1, 65536)
    if not rr1.is_ok() {
        tcp_close(client1)
        tcp_listener_close(listener1)
        return 8
    }
    let resp1: string = rr1!
    // Response should contain the body
    let body_start1: i32 = find_str(resp1, "\r\n\r\n", 0)
    if body_start1 >= 0 {
        let body1: string = resp1.slice(body_start1 + 4, resp1.len())
        assert_eq(body1, "Hello, World!")
    } else {
        tcp_close(client1)
        tcp_listener_close(listener1)
        return 8
    }

    tcp_close(client1)
    tcp_listener_close(listener1)

    // Test 7: JSON response
    let lr2: Result#[TcpListener, IoError] = tcp_listen("127.0.0.1", 19878)
    if not lr2.is_ok() {
        return 9
    }
    let listener2: TcpListener = lr2!

    let cr2: Result#[TcpStream, IoError] = tcp_connect("127.0.0.1", 19878)
    if not cr2.is_ok() {
        tcp_listener_close(listener2)
        return 9
    }
    let client2: TcpStream = cr2!
    let _w2: Result#[i32, IoError] = tcp_write(client2, "GET /api/data HTTP/1.1\r\nHost: 127.0.0.1\r\nConnection: close\r\n\r\n")

    let ar2: Result#[HttpConnection, string] = http_server_accept_on(listener2)
    if not ar2.is_ok() {
        tcp_close(client2)
        tcp_listener_close(listener2)
        return 10
    }
    let conn2: HttpConnection = ar2!

    http_server_respond(conn2, http_json_response("{\"message\":\"ok\"}"))

    let rr2: Result#[string, IoError] = tcp_read(client2, 65536)
    if not rr2.is_ok() {
        tcp_close(client2)
        tcp_listener_close(listener2)
        return 11
    }
    let resp2: string = rr2!
    let body_start2: i32 = find_str(resp2, "\r\n\r\n", 0)
    if body_start2 >= 0 {
        let body2: string = resp2.slice(body_start2 + 4, resp2.len())
        assert_eq(body2, "{\"message\":\"ok\"}")
    } else {
        tcp_close(client2)
        tcp_listener_close(listener2)
        return 11
    }

    tcp_close(client2)
    tcp_listener_close(listener2)

    return 0
}
